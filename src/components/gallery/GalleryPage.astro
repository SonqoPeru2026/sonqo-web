---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { Icon } from "astro-icon/components";
import { getLang, useTranslations } from "@/i18n/utils";
import { INSTAGRAM_HANDLE, INSTAGRAM_POSTS } from "@/data/instagram";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "gallery");

// Fotos locales: mismas de la galería del home. Astro las optimiza.
const galleryModules = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/images/gallery/*.webp",
  { eager: true },
);
const images = Object.entries(galleryModules)
  .sort(([a], [b]) => a.localeCompare(b, undefined, { numeric: true }))
  .map(([, mod]) => mod.default);

const igHref = `https://www.instagram.com/${INSTAGRAM_HANDLE}/`;
---

<!-- Padding-top para que el navbar fijo no tape el encabezado -->
<section class="bg-cream pb-24 pt-32 sm:pt-36">
  <!-- Encabezado -->
  <div class="mx-auto mb-12 w-full max-w-[1280px] px-6 text-center sm:px-8">
    <p class="font-heading text-sm font-bold uppercase tracking-[0.7px] text-primary">
      {t.pageEyebrow}
    </p>
    <h1 class="mt-3 font-heading text-4xl font-bold uppercase leading-tight text-burgundy sm:text-5xl">
      {t.pageTitle}
    </h1>
    <p class="mt-4 font-body text-ink sm:text-lg">{t.pageSubtitle}</p>
    <p class="mt-2 font-body text-sm text-ink/70">{t.lightboxHint}</p>
  </div>

  <!-- Grid de fotos -->
  <div class="mx-auto max-w-[1280px] px-4 sm:px-8">
    <ul
      id="photo-grid"
      class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4"
    >
      {
        images.map((src, i) => (
          <li>
            <button
              type="button"
              class="group block aspect-square w-full overflow-hidden rounded-2xl shadow-[0px_10px_30px_-12px_rgb(0_0_0/0.25)] focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
              data-lightbox
              data-index={i}
            >
              <Image
                src={src}
                alt={t.imageAlt}
                loading={i < 4 ? "eager" : "lazy"}
                width={720}
                height={720}
                quality={72}
                sizes="(min-width: 1024px) 300px, (min-width: 640px) 33vw, 50vw"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.06]"
              />
            </button>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- Sección Instagram -->
  <div class="mx-auto mt-24 max-w-[1280px] px-6 sm:px-8">
    <div class="mb-10 text-center">
      <p class="font-heading text-sm font-bold uppercase tracking-[0.7px] text-primary">
        {t.igEyebrow}
      </p>
      <h2 class="mt-3 font-heading text-3xl font-bold uppercase leading-tight text-burgundy sm:text-4xl">
        {t.igTitle}
      </h2>
      <p class="mt-4 font-body text-ink sm:text-lg">{t.igSubtitle}</p>
    </div>

    <ul class="grid grid-cols-1 justify-items-center gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        INSTAGRAM_POSTS.map((code) => (
          <li class="w-full max-w-[400px]">
            <blockquote
              class="instagram-media"
              data-instgrm-permalink={`https://www.instagram.com/p/${code}/`}
              data-instgrm-version="14"
              style="margin:0;width:100%;min-width:0;border-radius:16px;overflow:hidden;box-shadow:0 10px 30px -12px rgb(0 0 0/0.3)"
            />
          </li>
        ))
      }
    </ul>

    <div class="mt-12 text-center">
      <a
        href={igHref}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-2.5 rounded-full border-[1.5px] border-primary px-7 py-3.5 font-heading text-sm font-bold uppercase tracking-wide text-primary transition-colors hover:bg-primary hover:text-white"
      >
        {t.igCta}
        <Icon name="arrow" class="h-4 w-auto transition-transform group-hover:translate-x-1" />
      </a>
    </div>
  </div>
</section>

<!-- Lightbox -->
<div
  id="lightbox"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 p-4"
  role="dialog"
  aria-modal="true"
  aria-label={t.pageTitle}
>
  <button
    type="button"
    id="lb-close"
    class="absolute right-4 top-4 flex size-11 items-center justify-center rounded-full bg-white/15 text-white transition hover:bg-white/25"
    aria-label="Cerrar"
  >
    <Icon name="close" class="size-6" />
  </button>
  <button
    type="button"
    id="lb-prev"
    class="absolute left-2 top-1/2 flex size-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/15 text-white transition hover:bg-white/25 sm:left-6"
    aria-label="Anterior"
  >
    <Icon name="chevron-left" class="size-6" />
  </button>
  <img id="lb-img" src="" alt="" class="max-h-[85vh] max-w-[90vw] rounded-xl object-contain" />
  <button
    type="button"
    id="lb-next"
    class="absolute right-2 top-1/2 flex size-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/15 text-white transition hover:bg-white/25 sm:right-6"
    aria-label="Siguiente"
  >
    <Icon name="chevron-right" class="size-6" />
  </button>
</div>

<script>
  function initGallery() {
    const grid = document.getElementById("photo-grid");
    const lightbox = document.getElementById("lightbox");
    const lbImg = document.getElementById("lb-img") as HTMLImageElement | null;
    if (!grid || !lightbox || !lbImg) return;

    // Fuentes de las fotos, en orden, para navegar en el lightbox.
    const sources = Array.from(
      grid.querySelectorAll<HTMLImageElement>("img"),
    ).map((img) => ({ src: img.currentSrc || img.src, alt: img.alt }));
    let current = 0;

    const show = (i: number) => {
      current = (i + sources.length) % sources.length;
      lbImg.src = sources[current].src;
      lbImg.alt = sources[current].alt;
    };
    const open = (i: number) => {
      show(i);
      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
      document.documentElement.classList.add("overflow-hidden");
    };
    const close = () => {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      document.documentElement.classList.remove("overflow-hidden");
    };

    grid.querySelectorAll<HTMLButtonElement>("[data-lightbox]").forEach((btn) => {
      btn.addEventListener("click", () =>
        open(Number(btn.dataset.index ?? 0)),
      );
    });

    document.getElementById("lb-close")?.addEventListener("click", close);
    document
      .getElementById("lb-prev")
      ?.addEventListener("click", () => show(current - 1));
    document
      .getElementById("lb-next")
      ?.addEventListener("click", () => show(current + 1));
    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) close();
    });
    document.addEventListener("keydown", (e) => {
      if (lightbox.classList.contains("hidden")) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowLeft") show(current - 1);
      if (e.key === "ArrowRight") show(current + 1);
    });

  }

  // Instagram: carga el script oficial embed.js una vez y re-procesa los
  // blockquotes en cada navegación (View Transitions no recarga la página).
  function renderInstagram() {
    const w = window as Window & { instgrm?: { Embeds: { process: () => void } } };
    if (w.instgrm) {
      w.instgrm.Embeds.process();
      return;
    }
    if (document.getElementById("ig-embed-js")) return;
    const s = document.createElement("script");
    s.id = "ig-embed-js";
    s.async = true;
    s.src = "https://www.instagram.com/embed.js";
    document.body.appendChild(s);
  }

  document.addEventListener("astro:page-load", () => {
    initGallery();
    renderInstagram();
  });
</script>

---
import { Icon } from "astro-icon/components";
import { getLang, useTranslations, localizePath } from "@/i18n/utils";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "campaign");
const donateHref = localizePath("/donate", lang);
---

<dialog
  data-welcome-modal
  aria-labelledby="welcome-title"
  class="welcome-modal m-auto w-[calc(100%-2rem)] max-w-sm overflow-hidden rounded-2xl bg-white p-0 shadow-[0_8px_40px_-8px_rgb(84_5_69/0.25)]"
>
  <div class="welcome-card relative">
    <button
      type="button"
      data-welcome-close
      aria-label={t.dismiss}
      class="welcome-close absolute right-3 top-3 z-10 flex size-7 items-center justify-center rounded-full bg-white/80 text-ink-500 opacity-0 transition-opacity hover:opacity-100 focus:outline-none"
    >
      <Icon name="close" class="h-3.5 w-auto" />
    </button>

    <div class="welcome-hero flex h-28 items-center justify-center bg-primary">
      <Icon name="campaign-heart" class="h-10 w-auto text-white" />
    </div>

    <div class="flex flex-col items-center px-6 py-5 text-center">
      <span
        class="welcome-eyebrow rounded-full bg-ink-50 px-3 py-1 font-heading text-xs font-bold uppercase tracking-[1.2px] text-primary opacity-0"
      >
        {t.welcomeEyebrow}
      </span>

      <h2 id="welcome-title" class="welcome-title mt-3.5 font-heading text-lg font-bold leading-7 text-ink-900 opacity-0">
        {t.welcomeTitle}
      </h2>

      <p class="welcome-text mt-3 max-w-[260px] font-body text-sm leading-relaxed text-ink-500 opacity-0">
        {t.welcomeText}
      </p>

      <a
        href={donateHref}
        class="welcome-cta mt-5 flex w-full items-center justify-center gap-2 rounded-full bg-primary px-6 py-3 font-heading text-sm font-semibold uppercase tracking-wide text-white shadow-[0_2px_8px_-2px_rgb(182_0_48/0.3)] transition-colors hover:bg-primary-600 opacity-0"
      >
        <Icon name="campaign-heart" class="h-3.5 w-auto text-white" />
        {t.welcomeCta}
      </a>

      <button
        type="button"
        data-welcome-close
        class="welcome-later mt-3 flex items-center gap-1.5 font-body text-xs text-ink-500 transition-colors hover:text-burgundy opacity-0"
      >
        {t.dismiss}
        <Icon name="arrow" class="h-2.5 w-auto" />
      </button>
    </div>
  </div>
</dialog>

<script>
  function initWelcomeModal() {
    const modal = document.querySelector<HTMLDialogElement>("[data-welcome-modal]");
    if (!modal || modal.dataset.bound) return;
    modal.dataset.bound = "true";

    modal.querySelectorAll("[data-welcome-close]").forEach((btn) =>
      btn.addEventListener("click", () => {
        localStorage.setItem("sonqo-welcome", "1");
        modal.close();
      }),
    );

    modal.addEventListener("cancel", () => {
      localStorage.setItem("sonqo-welcome", "1");
    });

    modal.addEventListener("click", (e) => {
      if (e.target === modal) {
        localStorage.setItem("sonqo-welcome", "1");
        modal.close();
      }
    });

    if (localStorage.getItem("sonqo-welcome") === "1") return;

    let triggered = false;

    function showModal() {
      if (triggered || !modal) return;
      triggered = true;
      modal.showModal();
    }

    const timer = setTimeout(showModal, 5000);

    const main = document.querySelector("main");
    if (main) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            clearTimeout(timer);
            showModal();
          }
        },
        { threshold: 0.3 },
      );
      observer.observe(main);
    }
  }

  document.addEventListener("astro:page-load", initWelcomeModal);
</script>

<style>
  .welcome-modal::backdrop {
    background-color: rgb(0 0 0 / 0.3);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .welcome-modal[open] .welcome-card {
    animation: welcome-pop 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .welcome-modal[open] .welcome-close {
    animation: welcome-fade-in 0.25s 0.5s ease both;
  }
  .welcome-modal[open] .welcome-eyebrow {
    animation: welcome-fade-up 0.3s 0.1s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .welcome-modal[open] .welcome-title {
    animation: welcome-fade-up 0.3s 0.2s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .welcome-modal[open] .welcome-text {
    animation: welcome-fade-up 0.3s 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .welcome-modal[open] .welcome-cta {
    animation: welcome-pop-cta 0.35s 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .welcome-modal[open] .welcome-later {
    animation: welcome-fade-up 0.25s 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes welcome-pop {
    from { opacity: 0; transform: scale(0.92); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes welcome-fade-up {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes welcome-fade-in {
    from { opacity: 0; }
    to { opacity: 0.7; }
  }

  @keyframes welcome-pop-cta {
    from { opacity: 0; transform: translateY(8px) scale(0.96); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .welcome-modal[open] .welcome-card,
    .welcome-modal[open] .welcome-close,
    .welcome-modal[open] .welcome-eyebrow,
    .welcome-modal[open] .welcome-title,
    .welcome-modal[open] .welcome-text,
    .welcome-modal[open] .welcome-cta,
    .welcome-modal[open] .welcome-later {
      animation: none !important;
    }
    .welcome-modal[open] .welcome-close { opacity: 0.7; }
    .welcome-modal[open] .welcome-eyebrow,
    .welcome-modal[open] .welcome-title,
    .welcome-modal[open] .welcome-text,
    .welcome-modal[open] .welcome-cta,
    .welcome-modal[open] .welcome-later { opacity: 1; }
  }
</style>

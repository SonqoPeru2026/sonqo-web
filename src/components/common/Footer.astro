---
import { getLang, useTranslations } from "@/i18n/utils";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "footer");
const year = new Date().getFullYear();
---

<footer class="border-t border-pink-200/40 py-8">
  <div class="mx-auto max-w-6xl px-4 text-center font-body text-sm text-burgundy">
    © {year} Sonqo — {t.rights}
  </div>
</footer>

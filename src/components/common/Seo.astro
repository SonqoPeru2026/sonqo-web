---
import { getLang } from "@/i18n/utils";
import {
  SITE_NAME,
  DEFAULT_OG_IMAGE,
  OG_LOCALE,
  HREFLANG,
  buildAlternates,
  organizationSchema,
  websiteSchema,
} from "@/lib/seo";

interface Props {
  title: string;
  description: string;
  /** Imagen para previews. Ruta relativa a la raíz. Default: og-image global. */
  image?: string;
  /** Tipo Open Graph. "website" por defecto; "article" para blog en V2. */
  ogType?: "website" | "article";
  /** true en páginas que no deben indexarse (checkout, thanks). */
  noindex?: boolean;
}

const {
  title,
  description,
  image = DEFAULT_OG_IMAGE,
  ogType = "website",
  noindex = false,
} = Astro.props;

const lang = getLang(Astro.url);
const site = Astro.site;

// Canonical: la URL de esta página sin query ni trailing slash.
const canonical = new URL(Astro.url.pathname, site).href;
const alternates = buildAlternates(site, Astro.url.pathname);
const imageUrl = new URL(image, site).href;

// El schema de organización va en todo el sitio; el de WebSite solo en la home.
const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "/en";
const schemas = [
  organizationSchema(site),
  ...(isHome ? [websiteSchema(site)] : []),
];
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

{/* hreflang — le dice a Google qué versión servir según el idioma del usuario. */}
<link rel="alternate" hreflang={HREFLANG.es} href={alternates.es} />
<link rel="alternate" hreflang={HREFLANG.en} href={alternates.en} />
<link rel="alternate" hreflang="x-default" href={alternates.xDefault} />

{/* Open Graph — preview al compartir en WhatsApp, Facebook, LinkedIn, Slack. */}
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content={OG_LOCALE[lang]} />
<meta
  property="og:locale:alternate"
  content={OG_LOCALE[lang === "es" ? "en" : "es"]}
/>

{/* Twitter / X Card. */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

{/* JSON-LD — datos estructurados que habilitan rich results y knowledge panel. */}
{
  schemas.map((schema) => (
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(schema)}
    />
  ))
}

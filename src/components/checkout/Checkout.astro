---
import { Icon } from "astro-icon/components";
import { getLang, useTranslations, localizePath } from "@/i18n/utils";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "checkout");
const pkg = useTranslations(lang, "packageCard");

// Paquetes (precios editables en Sanity más adelante). El paquete elegido llega
// por query string: /checkout?package=ninos. Por defecto, "aliado".
const packages = {
  aliado: { name: pkg.aliadoName, price: 33, impact: pkg.impact1 },
  ninos: { name: pkg.ninosName, price: 165, impact: pkg.impact5 },
  corazon: { name: pkg.corazonName, price: 330, impact: pkg.impact10 },
  comunidad: { name: pkg.comunidadName, price: 660, impact: pkg.impact20 },
} as const;

type PackageId = keyof typeof packages;

const rawAmount = Astro.url.searchParams.get("amount");
const customAmount = rawAmount ? Math.round(Number(rawAmount)) : NaN;
const isCustom = Number.isFinite(customAmount) && customAmount >= 10;

const requested = Astro.url.searchParams.get("package");
const selectedId: PackageId =
  requested && requested in packages ? (requested as PackageId) : "aliado";

const summary = isCustom
  ? { name: t.customName, impact: t.customImpact, price: customAmount }
  : packages[selectedId];

const amount = `${t.currency} ${summary.price.toFixed(2)}`;
const donateHref = localizePath("/donate", lang);

const inputClass =
  "w-full rounded-lg border border-ink-200 bg-white px-4 py-3 font-body text-burgundy-900 placeholder:text-ink-400 transition-colors focus:border-primary focus:outline-none";
const labelClass = "mb-2 block font-body text-sm font-medium text-ink-500";

const methods = [
  { id: "card", label: t.methodCard, icon: "checkout-card" },
  { id: "transfer", label: t.methodTransfer, icon: "checkout-transfer" },
  { id: "yape", label: t.methodYape, icon: "checkout-yape" },
];

// Indicador de progreso del checkout. "done" = paso completado (link de vuelta),
// "current" = paso actual (aria-current="step"), "upcoming" = pendiente.
const homeHref = localizePath("/", lang);
type Step = { label: string; href?: string; state: "done" | "current" | "upcoming" };
const steps: Step[] = [
  { label: t.stepHome, href: homeHref, state: "done" },
  { label: t.stepDonation, href: donateHref, state: "done" },
  { label: t.stepPayment, state: "current" },
];
---

<section class="bg-mist pb-24 pt-[140px]">
  <div class="mx-auto w-full max-w-[1280px] px-6 sm:px-8">
    <!-- Indicador de progreso (lista ordenada = secuencia de pasos) -->
    <nav aria-label={t.stepsLabel} class="mb-8">
      <ol class="flex flex-wrap items-center gap-2 font-heading text-sm font-bold">
        {
          steps.map((step, i) => (
            <li class="flex items-center gap-2">
              {step.state === "done" && step.href ? (
                <a href={step.href} class="text-ink-400 transition-colors hover:text-burgundy">
                  {step.label}
                </a>
              ) : (
                <span
                  class={step.state === "current" ? "text-primary" : "text-ink-400"}
                  aria-current={step.state === "current" ? "step" : undefined}
                >
                  {step.label}
                </span>
              )}
              {i < steps.length - 1 && (
                <span class="text-ink-300" aria-hidden="true">
                  ›
                </span>
              )}
            </li>
          ))
        }
      </ol>
    </nav>

    <!-- Encabezado -->
    <header class="mb-12 max-w-2xl">
      <p class="font-heading text-sm font-bold uppercase tracking-[0.2em] text-primary">
        {t.pageKicker}
      </p>
      <h1 class="mt-3 font-heading text-4xl font-bold text-burgundy sm:text-5xl">
        {t.pageTitle}
      </h1>
      <p class="mt-4 font-body text-lg text-ink">{t.pageSubtitle}</p>
    </header>

    <div class="grid gap-10 md:grid-cols-[1.5fr_1fr] md:gap-14">
      <!-- ============ Columna izquierda: formulario ============ -->
      <form data-checkout-form novalidate>
        <!-- Información de contacto -->
        <h2 class="font-heading text-xl font-bold text-burgundy">{t.contactHeading}</h2>

        <div class="mt-6 grid gap-6 sm:grid-cols-2">
          <div>
            <label class={labelClass} for="firstName">{t.firstNameLabel}</label>
            <input id="firstName" name="firstName" type="text" required
              placeholder={t.firstNamePlaceholder} class={inputClass} />
          </div>
          <div>
            <label class={labelClass} for="lastName">{t.lastNameLabel}</label>
            <input id="lastName" name="lastName" type="text" required
              placeholder={t.lastNamePlaceholder} class={inputClass} />
          </div>
        </div>

        <div class="mt-6">
          <label class={labelClass} for="email">{t.emailLabel}</label>
          <input id="email" name="email" type="email" required
            placeholder={t.emailPlaceholder} class={inputClass} />
        </div>

        <div class="mt-6">
          <label class={labelClass} for="phone">{t.phoneLabel}</label>
          <input id="phone" name="phone" type="tel"
            placeholder={t.phonePlaceholder} class={inputClass} />
        </div>

        <hr class="my-10 border-ink-200" />

        <!-- Método de pago -->
        <h2 class="font-heading text-xl font-bold text-burgundy">{t.paymentHeading}</h2>

        <div class="mt-6 flex flex-wrap gap-3" role="tablist" data-method-tabs>
          {
            methods.map((m, i) => (
              <button
                type="button"
                role="tab"
                data-method={m.id}
                aria-selected={i === 0 ? "true" : "false"}
                class="inline-flex items-center gap-2 rounded-full bg-white px-5 py-2.5 font-heading text-sm font-bold text-ink-500 ring-1 ring-ink-200 transition-all hover:text-burgundy aria-selected:text-primary aria-selected:ring-2 aria-selected:ring-primary"
              >
                <Icon name={m.icon} class="h-4 w-auto" />
                {m.label}
              </button>
            ))
          }
        </div>

        <!-- Panel: tarjeta -->
        <div data-method-panel="card" class="mt-8">
          <div>
            <label class={labelClass} for="cardNumber">{t.cardNumberLabel}</label>
            <div class="relative">
              <Icon name="checkout-card"
                class="pointer-events-none absolute left-4 top-1/2 h-4 w-auto -translate-y-1/2 text-ink-400" />
              <input id="cardNumber" name="cardNumber" type="text" inputmode="numeric"
                placeholder={t.cardNumberPlaceholder} class={`${inputClass} pl-11`} />
            </div>
          </div>

          <div class="mt-6">
            <label class={labelClass} for="cardName">{t.cardNameLabel}</label>
            <input id="cardName" name="cardName" type="text"
              placeholder={t.cardNamePlaceholder} class={inputClass} />
          </div>

          <div class="mt-6 grid gap-6 sm:grid-cols-2">
            <div>
              <label class={labelClass} for="cardExpiry">{t.cardExpiryLabel}</label>
              <input id="cardExpiry" name="cardExpiry" type="text" inputmode="numeric"
                placeholder={t.cardExpiryPlaceholder} class={inputClass} />
            </div>
            <div>
              <label class={labelClass} for="cardCvv">{t.cardCvvLabel}</label>
              <input id="cardCvv" name="cardCvv" type="text" inputmode="numeric"
                placeholder={t.cardCvvPlaceholder} class={inputClass} />
            </div>
          </div>
        </div>

        <!-- Panel: transferencia -->
        <div data-method-panel="transfer" class="mt-8 hidden">
          <p class="rounded-xl bg-white p-5 font-body text-sm leading-relaxed text-ink ring-1 ring-ink-200">
            {t.transferNote}
          </p>
        </div>

        <!-- Panel: Yape/Plin -->
        <div data-method-panel="yape" class="mt-8 hidden">
          <p class="rounded-xl bg-white p-5 font-body text-sm leading-relaxed text-ink ring-1 ring-ink-200">
            {t.yapeNote}
          </p>
        </div>

        <!-- Sellos de confianza -->
        <div class="mt-8 flex flex-wrap items-center justify-between gap-4">
          <span class="inline-flex items-center gap-2 font-body text-sm text-ink-500">
            <Icon name="hero-lock" class="h-4 w-auto text-primary" />
            {t.secureLabel}
          </span>
          <div class="flex items-center gap-2 text-ink-300">
            <Icon name="donate-visa" class="h-4 w-auto" />
            <Icon name="donate-mastercard-1" class="h-6 w-auto" />
            <Icon name="donate-ssl" class="h-6 w-auto" />
          </div>
        </div>

        <!-- CTA -->
        <button type="submit"
          class="mt-8 flex w-full items-center justify-center gap-3 rounded-full bg-primary px-6 py-4 font-heading text-base font-bold uppercase tracking-wide text-white transition-colors hover:bg-primary-600">
          <Icon name="purpose-heart" class="h-5 w-auto" />
          {t.submit}
        </button>

        <p class="mt-4 text-center font-body text-sm text-ink-400">
          {t.termsBefore}<a href="#" class="font-medium text-primary underline">{t.termsLink}</a>
        </p>
      </form>

      <!-- ============ Columna derecha: resumen ============ -->
      <aside>
        <div class="rounded-3xl bg-white p-8 shadow-[0px_24px_60px_-30px_rgb(84_5_69/0.25)]">
          <div class="flex flex-col items-center text-center">
            <span class="flex h-14 w-14 items-center justify-center rounded-full bg-primary">
              <Icon name="purpose-heart" class="h-6 w-auto text-white" />
            </span>
            <p class="mt-4 font-heading text-sm font-bold uppercase tracking-[0.2em] text-primary">
              {t.summaryKicker}
            </p>
          </div>

          <hr class="my-6 border-ink-100" />

          <h2 class="text-center font-heading text-xl font-bold text-burgundy">{summary.name}</h2>
          <p class="mt-2 text-center font-body text-sm text-ink">{summary.impact}</p>

          <div class="mt-6 overflow-hidden rounded-2xl bg-mist">
            <img src="/images/checkout-photo.webp" alt={summary.name}
              width="440" height="440" class="h-auto w-full" />
          </div>

          <dl class="mt-8 space-y-4">
            <div class="flex items-center justify-between font-body text-ink-500">
              <dt>{t.subtotalLabel}</dt>
              <dd>{amount}</dd>
            </div>
            <div class="flex items-baseline justify-between border-t border-ink-100 pt-4">
              <dt class="font-heading text-lg font-bold text-burgundy">{t.totalLabel}</dt>
              <dd class="font-heading text-2xl font-bold text-primary">{amount}</dd>
            </div>
          </dl>

          <p class="mt-6 flex items-center justify-center gap-2 rounded-full bg-mist px-4 py-3 font-body text-sm font-medium text-burgundy">
            <Icon name="check" class="h-4 w-4 rounded-full bg-primary p-0.5 text-white" />
            {t.guarantee}
          </p>

          <a href={donateHref}
            class="mt-4 block text-center font-heading text-sm font-bold text-primary underline-offset-4 hover:underline">
            {t.changeAmount}
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
  // Cambia el método de pago (tarjeta / transferencia / yape) mostrando su panel.
  function initCheckout() {
    const form = document.querySelector<HTMLElement>("[data-checkout-form]");
    if (!form) return;

    const tabs = form.querySelectorAll<HTMLButtonElement>("[data-method]");
    const panels = form.querySelectorAll<HTMLElement>("[data-method-panel]");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const method = tab.dataset.method;
        tabs.forEach((t) => t.setAttribute("aria-selected", String(t === tab)));
        panels.forEach((panel) => {
          panel.classList.toggle("hidden", panel.dataset.methodPanel !== method);
        });
      });
    });

    // El pago real (MercadoPago) aún no está integrado: ver /api/create-preference.
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      console.info("[checkout] envío pendiente de integración de pagos");
    });
  }

  document.addEventListener("astro:page-load", initCheckout);
</script>

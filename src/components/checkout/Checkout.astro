---
import { Icon } from "astro-icon/components";
import { getLang, useTranslations, localizePath } from "@/i18n/utils";
import { PACKAGES } from "@/lib/donation";
import { PUBLIC_MP_PUBLIC_KEY } from "astro:env/client";
import PaymentBrick from "@/components/checkout/PaymentBrick";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "checkout");
const pkg = useTranslations(lang, "packageCard");

const packages = {
  aliado: { name: pkg.aliadoName, price: PACKAGES.aliado.price, impact: pkg.impact1 },
  ninos: { name: pkg.ninosName, price: PACKAGES.ninos.price, impact: pkg.impact5 },
  corazon: { name: pkg.corazonName, price: PACKAGES.corazon.price, impact: pkg.impact10 },
  comunidad: { name: pkg.comunidadName, price: PACKAGES.comunidad.price, impact: pkg.impact20 },
} as const;

type PackageId = keyof typeof packages;

const rawAmount = Astro.url.searchParams.get("amount");
const customAmount = rawAmount ? Math.round(Number(rawAmount)) : NaN;
const isCustom = Number.isFinite(customAmount) && customAmount >= 10;

const requested = Astro.url.searchParams.get("package");
const selectedId: PackageId =
  requested && requested in packages ? (requested as PackageId) : "aliado";

const summary = isCustom
  ? { name: t.customName, impact: t.customImpact, price: customAmount }
  : packages[selectedId];

const amount = `${t.currency} ${summary.price.toFixed(2)}`;
const donateHref = localizePath("/donate", lang);
const thanksHref = localizePath("/thanks", lang);

// Pagos con tarjeta vía MercadoPago Brick. Sin keys, se muestra el placeholder.
const paymentsReady = Boolean(PUBLIC_MP_PUBLIC_KEY);
const brickPackageId = isCustom ? undefined : selectedId;

const inputClass =
  "w-full rounded-lg border border-ink-200 bg-white px-4 py-3 font-body text-burgundy-900 placeholder:text-ink-400 transition-colors focus:border-primary focus:outline-none aria-[invalid=true]:border-primary";
const labelClass = "mb-2 block font-body text-sm font-medium text-ink-500";
const errorClass = "mt-1 hidden font-body text-xs text-primary";

// Mensajes de error de contacto → validación en vivo con el mismo schema zod del server
// (lib/validation/checkout-contact.ts).
const contactMessages = {
  firstName: t.firstNameError,
  lastName: t.lastNameError,
  email: t.emailError,
};

// Indicador de progreso del checkout. "done" = paso completado (link de vuelta),
// "current" = paso actual (aria-current="step"), "upcoming" = pendiente.
const homeHref = localizePath("/", lang);
type Step = { label: string; href?: string; state: "done" | "current" | "upcoming" };
const steps: Step[] = [
  { label: t.stepHome, href: homeHref, state: "done" },
  { label: t.stepDonation, href: donateHref, state: "done" },
  { label: t.stepPayment, state: "current" },
];
---

<section class="bg-mist pb-24 pt-[140px]">
  <div class="mx-auto w-full max-w-[1280px] px-6 sm:px-8">
    <!-- Indicador de progreso (lista ordenada = secuencia de pasos) -->
    <nav aria-label={t.stepsLabel} class="mb-8">
      <ol class="flex flex-wrap items-center gap-2 font-heading text-sm font-bold">
        {
          steps.map((step, i) => (
            <li class="flex items-center gap-2">
              {step.state === "done" && step.href ? (
                <a href={step.href} class="text-ink-400 transition-colors hover:text-burgundy">
                  {step.label}
                </a>
              ) : (
                <span
                  class={step.state === "current" ? "text-primary" : "text-ink-400"}
                  aria-current={step.state === "current" ? "step" : undefined}
                >
                  {step.label}
                </span>
              )}
              {i < steps.length - 1 && (
                <span class="text-ink-300" aria-hidden="true">
                  ›
                </span>
              )}
            </li>
          ))
        }
      </ol>
    </nav>

    <!-- Encabezado -->
    <header class="mb-12 max-w-2xl">
      <p class="font-heading text-sm font-bold uppercase tracking-[0.2em] text-primary">
        {t.pageKicker}
      </p>
      <h1 class="mt-3 font-heading text-4xl font-bold text-burgundy sm:text-5xl">
        {t.pageTitle}
      </h1>
      <p class="mt-4 font-body text-lg text-ink">{t.pageSubtitle}</p>
    </header>

    <div class="grid gap-10 md:grid-cols-[1.5fr_1fr] md:gap-14">
      <!-- ============ Columna izquierda: formulario ============ -->
      <form data-checkout-form novalidate data-messages={JSON.stringify(contactMessages)}>
        <!-- Información de contacto -->
        <h2 class="font-heading text-xl font-bold text-burgundy">{t.contactHeading}</h2>

        <div class="mt-6 grid gap-6 sm:grid-cols-2">
          <div>
            <label class={labelClass} for="firstName">{t.firstNameLabel}</label>
            <input id="firstName" name="firstName" type="text" required aria-describedby="firstName-error"
              placeholder={t.firstNamePlaceholder} class={inputClass} />
            <p id="firstName-error" data-error="firstName" class={errorClass}></p>
          </div>
          <div>
            <label class={labelClass} for="lastName">{t.lastNameLabel}</label>
            <input id="lastName" name="lastName" type="text" required aria-describedby="lastName-error"
              placeholder={t.lastNamePlaceholder} class={inputClass} />
            <p id="lastName-error" data-error="lastName" class={errorClass}></p>
          </div>
        </div>

        <div class="mt-6">
          <label class={labelClass} for="email">{t.emailLabel}</label>
          <input id="email" name="email" type="email" required aria-describedby="email-error"
            placeholder={t.emailPlaceholder} class={inputClass} />
          <p id="email-error" data-error="email" class={errorClass}></p>
        </div>

        <div class="mt-6">
          <label class={labelClass} for="phone">{t.phoneLabel}</label>
          <input id="phone" name="phone" type="tel"
            placeholder={t.phonePlaceholder} class={inputClass} />
        </div>

        <p data-contact-form-error role="alert" class="mt-4 hidden font-body text-sm text-primary">
          {t.contactIncompleteError}
        </p>

        <hr class="my-10 border-ink-200" />

        <!-- Consentimiento (obligatorio, registrado como prueba legal) -->
        <label class="flex items-start gap-3 font-body text-sm text-ink-500">
          <input
            type="checkbox"
            name="consent"
            required
            class="mt-0.5 size-4 shrink-0 rounded border-ink-300 text-primary focus:ring-primary/30"
          />
          <span>
            {t.termsBefore}{" "}
            <a
              href={localizePath("/terms", lang)}
              target="_blank"
              rel="noopener noreferrer"
              class="font-medium text-primary underline">{t.termsLink}</a>{" "}{t.termsAnd}{" "}
            <a
              href={localizePath("/privacy", lang)}
              target="_blank"
              rel="noopener noreferrer"
              class="font-medium text-primary underline">{t.privacyLink}</a>
          </span>
        </label>
        <p data-consent-error class:list={[errorClass, "mt-2"]}>{t.consentError}</p>

        <hr class="my-10 border-ink-200" />

        {
          paymentsReady ? (
            <PaymentBrick
              client:only="react"
              publicKey={PUBLIC_MP_PUBLIC_KEY ?? ""}
              amount={summary.price}
              packageId={brickPackageId}
              thanksHref={thanksHref}
            />
          ) : (
            <p class="rounded-xl bg-white p-5 text-center font-body text-sm text-ink-500 ring-1 ring-ink-200">
              {t.cardComingSoon}
            </p>
          )
        }

        <!-- Sellos de confianza -->
        <div class="mt-8 flex flex-wrap items-center justify-between gap-4">
          <span class="inline-flex items-center gap-2 font-body text-sm text-ink-500">
            <Icon name="hero-lock" class="h-4 w-auto text-primary" />
            {t.secureLabel}
          </span>
          <div class="flex items-center gap-2 text-ink-300">
            <Icon name="donate-visa" class="h-4 w-auto" />
            <Icon name="donate-mastercard-1" class="h-6 w-auto" />
            <Icon name="donate-ssl" class="h-6 w-auto" />
          </div>
        </div>

      </form>

      <!-- ============ Columna derecha: resumen ============ -->
      <aside>
        <div class="rounded-3xl bg-white p-8 shadow-[0px_24px_60px_-30px_rgb(84_5_69/0.25)]">
          <div class="flex flex-col items-center text-center">
            <span class="flex h-14 w-14 items-center justify-center rounded-full bg-primary">
              <Icon name="purpose-heart" class="h-6 w-auto text-white" />
            </span>
            <p class="mt-4 font-heading text-sm font-bold uppercase tracking-[0.2em] text-primary">
              {t.summaryKicker}
            </p>
          </div>

          <hr class="my-6 border-ink-100" />

          <h2 class="text-center font-heading text-xl font-bold text-burgundy">{summary.name}</h2>
          <p class="mt-2 text-center font-body text-sm text-ink">{summary.impact}</p>

          <div class="mt-6 overflow-hidden rounded-2xl bg-mist">
            <img src="/images/checkout-photo.webp" alt={summary.name}
              width="440" height="440" class="h-auto w-full" />
          </div>

          <dl class="mt-8 space-y-4">
            <div class="flex items-center justify-between font-body text-ink-500">
              <dt>{t.subtotalLabel}</dt>
              <dd>{amount}</dd>
            </div>
            <div class="flex items-baseline justify-between border-t border-ink-100 pt-4">
              <dt class="font-heading text-lg font-bold text-burgundy">{t.totalLabel}</dt>
              <dd class="font-heading text-2xl font-bold text-primary">{amount}</dd>
            </div>
          </dl>

          <p class="mt-6 flex items-center justify-center gap-2 rounded-full bg-mist px-4 py-3 font-body text-sm font-medium text-burgundy">
            <Icon name="check" class="h-4 w-4 rounded-full bg-primary p-0.5 text-white" />
            {t.guarantee}
          </p>

          <a href={donateHref}
            class="mt-4 block text-center font-heading text-sm font-bold text-primary underline-offset-4 hover:underline">
            {t.changeAmount}
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
  import { makeCheckoutContactSchema, type CheckoutContactMessages } from "@/lib/validation/checkout-contact";
  import { CONTACT_CHANGE_EVENT, CONTACT_INVALID_EVENT } from "@/components/checkout/checkout-contact";
  import type { CheckoutContact } from "@/components/checkout/checkout-contact";

  function initCheckoutContact() {
    const form = document.querySelector<HTMLFormElement>("[data-checkout-form]");
    if (!form || form.dataset.bound) return;
    form.dataset.bound = "true";

    const fields = {
      firstName: form.querySelector<HTMLInputElement>("#firstName"),
      lastName: form.querySelector<HTMLInputElement>("#lastName"),
      email: form.querySelector<HTMLInputElement>("#email"),
      phone: form.querySelector<HTMLInputElement>("#phone"),
    };
    const consentInput = form.querySelector<HTMLInputElement>("[name=consent]");
    const consentErrorEl = form.querySelector<HTMLElement>("[data-consent-error]");
    const formErrorEl = form.querySelector<HTMLElement>("[data-contact-form-error]");
    const errorEls = form.querySelectorAll<HTMLElement>("[data-error]");

    // Mismo schema que el server (paymentSchema lo extiende) — una sola fuente de verdad.
    const messages = JSON.parse(form.dataset.messages ?? "{}") as CheckoutContactMessages;
    const schema = makeCheckoutContactSchema(messages);

    const readValues = (): CheckoutContact => ({
      firstName: fields.firstName?.value.trim() ?? "",
      lastName: fields.lastName?.value.trim() ?? "",
      email: fields.email?.value.trim() ?? "",
      phone: fields.phone?.value.trim() ?? "",
      consent: consentInput?.checked ?? false,
    });

    // Valida con zod. Si showErrors, pinta los mensajes por campo (no bloquea nada acá:
    // el Brick trae su propio botón "Pagar", ver PaymentBrick.tsx / CONTACT_INVALID_EVENT).
    function validate(showErrors: boolean): boolean {
      const result = schema.safeParse(readValues());
      const errors: Record<string, string> = {};
      if (!result.success) {
        for (const issue of result.error.issues) {
          const field = issue.path[0];
          if (typeof field === "string" && !(field in errors)) errors[field] = issue.message;
        }
      }

      errorEls.forEach((el) => {
        const field = el.dataset.error!;
        const msg = errors[field];
        const input = form!.querySelector<HTMLElement>(`#${field}`);
        if (showErrors && msg) {
          el.textContent = msg;
          el.classList.remove("hidden");
          input?.setAttribute("aria-invalid", "true");
        } else {
          el.classList.add("hidden");
          input?.removeAttribute("aria-invalid");
        }
      });

      // Consentimiento: casilla obligatoria, aparte del schema de contacto.
      const consentOk = consentInput?.checked ?? false;
      if (showErrors && !consentOk) consentErrorEl?.classList.remove("hidden");
      else consentErrorEl?.classList.add("hidden");

      return result.success && consentOk;
    }

    const sync = () => {
      const contact = readValues();
      window.__checkoutContact = contact;
      document.dispatchEvent(new CustomEvent(CONTACT_CHANGE_EVENT, { detail: contact }));
      validate(false); // limpia errores mientras escribe
    };

    Object.values(fields).forEach((field) => {
      field?.addEventListener("input", sync);
      field?.addEventListener("blur", () => validate(true));
    });
    consentInput?.addEventListener("change", () => {
      sync();
      validate(true);
    });
    sync();

    // Sin submit propio: el Brick trae su botón "Pagar" (ver PaymentBrick.tsx). Si el
    // donante hace click en "Pagar" con el contacto incompleto, el Brick dispara esto
    // en vez de cobrar: pintamos los errores y llevamos la vista al formulario.
    document.addEventListener(CONTACT_INVALID_EVENT, () => {
      validate(true);
      formErrorEl?.classList.remove("hidden");
      form?.scrollIntoView({ behavior: "smooth", block: "start" });
    });

    form.addEventListener("input", () => formErrorEl?.classList.add("hidden"));
    form.addEventListener("submit", (e) => e.preventDefault());
  }

  document.addEventListener("astro:page-load", initCheckoutContact);
</script>

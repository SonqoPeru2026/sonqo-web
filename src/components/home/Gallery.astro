---
import { Icon } from "astro-icon/components";
import { getLang, useTranslations, localizePath } from "@/i18n/utils";
import InstagramEmbeds from "@/components/common/InstagramEmbeds.astro";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "gallery");
const galleryHref = localizePath("/gallery", lang);
---

<section id="gallery" class="overflow-hidden bg-mist py-24">
  <!-- Encabezado -->
  <div class="mx-auto mb-12 w-full max-w-[1280px] px-6 text-center sm:px-8">
    <p class="font-heading text-sm font-bold uppercase tracking-[0.7px] text-primary">
      {t.eyebrow}
    </p>
    <h2 class="mt-3 font-heading text-3xl font-bold uppercase leading-tight text-burgundy sm:text-4xl lg:text-5xl">
      {t.title}
    </h2>
    <p class="mt-4 font-body text-ink sm:text-lg">{t.subtitle}</p>
  </div>

  <!-- Grid de Instagram: 3 publicaciones reales como testimonio visual -->
  <InstagramEmbeds limit={3} />

  <!-- CTA a la galería completa -->
  <div class="mt-12 text-center">
    <a
      href={galleryHref}
      class="group inline-flex items-center gap-2.5 rounded-full bg-primary px-7 py-3.5 font-heading text-sm font-bold uppercase tracking-wide text-white transition-colors hover:bg-primary-600"
    >
      {t.viewAll}
      <Icon name="arrow" class="h-4 w-auto transition-transform group-hover:translate-x-1" />
    </a>
  </div>
</section>

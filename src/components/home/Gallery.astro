---
import { getLang, useTranslations } from "@/i18n/utils";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "gallery");

const images = [
  "1.jpg",
  "2.jpg",
  "3.jpg",
  "4.jpg",
  "5.jpg",
  "6.jpg",
  "7.jpg",
  "8.jpg",
];

const half = Math.ceil(images.length / 2);
const rowTop = images.slice(0, half);
const rowBottom = images.slice(half);

const rows = [
  { items: [...rowTop, ...rowTop], direction: "left" },
  { items: [...rowBottom, ...rowBottom], direction: "right" },
];
---

<section id="gallery" class="overflow-hidden bg-mist py-24">
  <!-- Encabezado -->
  <div class="mx-auto mb-12 w-full max-w-[1200px] px-6 text-center sm:px-8">
    <p class="font-heading text-sm font-bold uppercase tracking-[0.7px] text-primary">
      {t.eyebrow}
    </p>
    <h2 class="mt-3 font-heading text-3xl font-bold uppercase leading-tight text-burgundy sm:text-4xl lg:text-5xl">
      {t.title}
    </h2>
    <p class="mt-4 font-body text-ink sm:text-lg">{t.subtitle}</p>
  </div>

  <!-- Carrusel: 2 filas en direcciones opuestas -->
  <div class="mx-auto flex max-w-[1400px] flex-col gap-6 px-4 sm:px-8">
    {
      rows.map((row) => (
        <div class="marquee">
          <ul class:list={["marquee__track", row.direction === "right" && "marquee__track--reverse"]}>
            {row.items.map((src) => (
              <li class="marquee__item">
                <img
                  src={`/images/gallery/${src}`}
                  alt={t.imageAlt}
                  loading="lazy"
                  width="340"
                  height="240"
                  class="h-full w-full rounded-2xl object-cover shadow-[0px_10px_30px_-10px_rgb(0_0_0/0.2)]"
                />
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>

<style>
  .marquee {
    overflow: hidden;
  }
  .marquee__track {
    display: flex;
    width: max-content;
    gap: 1.5rem;
    padding-inline: 0.75rem;
    animation: marquee-scroll 45s linear infinite;
  }
  .marquee__track--reverse {
    animation-direction: reverse;
  }
  /* Pausa al pasar el mouse */
  .marquee:hover .marquee__track {
    animation-play-state: paused;
  }
  .marquee__item {
    flex: none;
    width: 200px;
    height: 150px;
  }

  @media (min-width: 640px) {
    .marquee__item {
      width: 320px;
      height: 220px;
    }
  }

  /* Se desplaza la mitad: como el contenido está duplicado, el bucle es continuo */
  @keyframes marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  /* Accesibilidad: sin movimiento si el usuario lo prefiere */
  @media (prefers-reduced-motion: reduce) {
    .marquee__track {
      animation: none;
    }
  }
</style>

---
import { Icon } from "astro-icon/components";
import { getLang, useTranslations } from "@/i18n/utils";
import { getSiteSettings } from "@/lib/sanity";
import { PACKAGES } from "@/lib/donation";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "motivation");

// Cifras editables por el equipo en Sanity (leídas en build). El costo de casaca
// se deriva del precio real del paquete Aliado (donation.ts) para no desincronizar.
const { ninosAtendidos, comunidades, solesRecaudados } = await getSiteSettings();
const fmt = (n: number) => n.toLocaleString("en-US");

const stats = [
  { icon: "achievements-jacket", prefix: "S/", value: PACKAGES.aliado.price, label: t.label1 },
  { icon: "achievements-comunity", prefix: "+", value: comunidades, label: t.label2 },
  { icon: "achievements-childrens", prefix: "", value: ninosAtendidos, label: t.label3 },
  { icon: "achievements-hand", prefix: "S/", value: solesRecaudados, label: t.label4 },
];
---

<section id="logros" class="bg-cream py-24">
  <div class="mx-auto w-full max-w-[1280px] px-6 sm:px-8">
    <!-- Encabezado -->
    <div class="grid gap-6 lg:grid-cols-2 lg:items-end">
      <div>
        <div class="flex items-center gap-4">
          <span class="h-0.5 w-8 bg-primary"></span>
          <span class="font-heading text-sm font-bold uppercase tracking-[0.7px] text-primary">
            {t.eyebrow}
          </span>
        </div>
        <h2 class="mt-6 font-heading text-3xl font-bold uppercase leading-tight text-burgundy sm:text-4xl lg:text-[40px]">
          {t.title}
        </h2>
      </div>
      <p class="font-medium leading-relaxed text-ink lg:text-right lg:text-lg">{t.subtitle}</p> 
    </div>

    <!-- Tarjetas de cifras -->
    <ul class="mt-20 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        stats.map((stat, i) => (
          <li
            data-reveal
            style={`--reveal-delay:${i * 150}ms`}
            class="group flex flex-col items-center rounded-3xl bg-white px-4 py-8 text-center shadow-[0px_10px_30px_-10px_rgb(0_0_0/0.05)] transition-[background-color,transform,box-shadow] duration-300 hover:-translate-y-1 hover:bg-primary hover:shadow-[0px_20px_40px_-12px_rgb(228_0_63/0.3)]"
          >
            <Icon
              name={stat.icon}
              class="h-14 w-auto text-primary transition-[color,transform] duration-300 group-hover:scale-110 group-hover:text-white"
            />
            <p class="mt-4 flex items-baseline justify-center gap-1 font-heading font-bold text-primary transition-colors group-hover:text-white">
              {stat.prefix && <span class="text-xl">{stat.prefix}</span>}
              <span class="text-4xl leading-none" data-count={stat.value}>{fmt(stat.value)}</span>
            </p>
            <p class="mt-3 whitespace-nowrap font-body text-xs font-medium uppercase tracking-[0.35px] text-ink transition-colors group-hover:text-white/90">
              {stat.label}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

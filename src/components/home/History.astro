---
import { Icon } from "astro-icon/components";
import { getLang, useTranslations } from "@/i18n/utils";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "history");

// Cifras oficiales por año (infografía "Nuestros logros"). 2026 es la meta.
const YEARS = [
  { year: 2016, value: 900, label: t.startLabel },
  { year: 2017, value: 2797 },
  { year: 2018, value: 3500 },
  { year: 2019, value: 5490, label: t.peakLabel, peak: true },
  { year: 2020, value: 2490 },
  { year: 2021, value: 3075 },
  { year: 2022, value: 3425 },
  { year: 2023, value: 2000 },
  { year: 2024, value: 3700 },
  { year: 2025, value: 4500 },
  { year: 2026, value: 5500, label: t.goalLabel, goal: true },
] as const;

const TOTAL = YEARS.filter((y) => !("goal" in y && y.goal)).reduce(
  (sum, y) => sum + y.value,
  0,
);
const MAX = Math.max(...YEARS.map((y) => y.value));
const pct = (v: number) => Math.round((v / MAX) * 100);
const fmt = (n: number) => n.toLocaleString("en-US");
---

<section id="history" class="overflow-hidden bg-mist py-24">
  <div class="mx-auto w-full max-w-[1100px] px-6 sm:px-8">
    <!-- Encabezado -->
    <div class="text-center">
      <p class="font-heading text-sm font-bold uppercase tracking-[0.7px] text-primary" data-reveal>
        {t.eyebrow}
      </p>
      <h2
        class="mt-4 font-heading text-2xl font-bold uppercase leading-tight text-burgundy sm:text-3xl lg:text-4xl"
        data-reveal
        style="--reveal-delay: 80ms"
      >
        {t.title}
      </h2>
    </div>

    <!-- Total acumulado: el número protagonista -->
    <div class="mt-12 text-center" data-reveal style="--reveal-delay: 160ms">
      <div class="inline-flex flex-col items-center">
        <span class="flex items-center gap-3">
          <Icon name="campaign-heart" class="size-8 text-primary sm:size-10" />
          <span
            class="font-heading text-6xl font-bold leading-none tabular-nums text-primary sm:text-7xl"
            data-count={TOTAL}
            data-count-dur="2200"
          >
            {fmt(TOTAL)}
          </span>
        </span>
        <span class="mt-3 font-body text-base text-ink sm:text-lg">{t.totalLabel}</span>
      </div>
    </div>

    <!-- Timeline / gráfico: barras verticales en sm+, horizontales en mobile -->
    <div class="mt-14" data-reveal style="--reveal-delay: 240ms">
      <!-- Desktop / tablet: barras verticales -->
      <ol class="hidden items-end gap-2 sm:flex lg:gap-3" role="list">
        {
          YEARS.map((y, i) => (
            <li class="group flex flex-1 flex-col items-center">
              <span
                class:list={[
                  "mb-2 font-heading text-xs font-bold tabular-nums transition-transform duration-300 group-hover:-translate-y-0.5 lg:text-sm",
                  "peak" in y && y.peak ? "text-primary" : "text-burgundy/70",
                ]}
              >
                {fmt(y.value)}
              </span>
              <div class="flex h-52 w-full items-end lg:h-64">
                <div
                  class:list={[
                    "bar-v w-full rounded-t-lg",
                    "goal" in y && y.goal
                      ? "border-2 border-dashed border-primary bg-primary-50"
                      : "peak" in y && y.peak
                        ? "bg-gradient-to-t from-primary-700 to-primary shadow-[0px_12px_30px_-8px_rgb(228_0_63/0.5)]"
                        : "bg-primary-200 transition-colors duration-300 group-hover:bg-primary-300",
                  ]}
                  style={`height:${pct(y.value)}%; --bar-delay:${i * 70}ms`}
                />
              </div>
              <span class="mt-2.5 font-heading text-xs font-bold tabular-nums text-burgundy lg:text-sm">
                {y.year}
              </span>
              <span class="mt-1 h-4 font-heading text-[10px] font-bold uppercase tracking-[0.5px] text-primary lg:text-[11px]">
                {"label" in y ? y.label : ""}
              </span>
            </li>
          ))
        }
      </ol>

      <!-- Mobile: barras horizontales -->
      <ol class="space-y-3 sm:hidden" role="list">
        {
          YEARS.map((y, i) => (
            <li class="flex items-center gap-3">
              <span class="w-11 shrink-0 font-heading text-sm font-bold tabular-nums text-burgundy">
                {y.year}
              </span>
              <div class="h-7 flex-1 overflow-hidden rounded-full bg-white/70">
                <div
                  class:list={[
                    "bar-h h-full rounded-full",
                    "goal" in y && y.goal
                      ? "border-2 border-dashed border-primary bg-primary-50"
                      : "peak" in y && y.peak
                        ? "bg-gradient-to-r from-primary to-primary-700"
                        : "bg-primary-200",
                  ]}
                  style={`width:${pct(y.value)}%; --bar-delay:${i * 60}ms`}
                />
              </div>
              <span
                class:list={[
                  "w-14 shrink-0 text-right font-heading text-xs font-bold tabular-nums",
                  "peak" in y && y.peak ? "text-primary" : "text-burgundy/70",
                ]}
              >
                {fmt(y.value)}
              </span>
            </li>
          ))
        }
      </ol>
    </div>

    <!-- Crecimiento + meta -->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-3 sm:gap-4">
      <div
        class="inline-flex items-center gap-2.5 rounded-full bg-white px-5 py-2.5 shadow-[0px_10px_24px_-12px_rgb(84_5_69/0.3)]"
        data-reveal
        style="--reveal-delay: 320ms"
      >
        <Icon name="growth" class="size-4 text-primary" />
        <span class="font-heading text-base font-bold tabular-nums text-primary">{t.growthValue}</span>
        <span class="font-body text-sm text-ink">{t.growthLabel}</span>
      </div>
      <div
        class="inline-flex items-center gap-2.5 rounded-full bg-primary px-5 py-2.5 text-white shadow-[0px_12px_28px_-10px_rgb(228_0_63/0.55)]"
        data-reveal
        style="--reveal-delay: 400ms"
      >
        <span class="font-heading text-sm font-bold uppercase tracking-[0.5px]">{t.goalChip}</span>
        <span class="font-heading text-base font-bold tabular-nums">5,500</span>
        <span class="font-body text-sm text-white/80">{t.goalUnit}</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* Las barras crecen cuando el wrapper [data-reveal] recibe .is-visible
     (motor global en Animations.astro). Escalonado con --bar-delay. */
  .bar-v {
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--bar-delay, 0ms);
    will-change: transform;
  }
  .bar-h {
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--bar-delay, 0ms);
    will-change: transform;
  }
  :global([data-reveal].is-visible) .bar-v {
    transform: scaleY(1);
  }
  :global([data-reveal].is-visible) .bar-h {
    transform: scaleX(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .bar-v,
    .bar-h {
      transform: none;
      transition: none;
    }
  }
</style>

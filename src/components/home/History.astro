---
import { Icon } from "astro-icon/components";
import { getLang, useTranslations } from "@/i18n/utils";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "history");

// Solo cifras oficiales: comienzo (2016), pico histórico (2019) y meta (2026).
const milestones = [
  { year: 2016, value: 900, role: t.startLabel, highlight: false },
  { year: 2019, value: 5490, role: t.peakLabel, highlight: true },
  { year: 2026, value: 5500, role: t.goalLabel, highlight: false },
];
const fmt = (n: number) => n.toLocaleString("en-US");
---

<section id="history" class="bg-mist py-24">
  <div class="mx-auto w-full max-w-[1100px] px-6 sm:px-8">
    <!-- Encabezado -->
    <div class="text-center">
      <p class="font-heading text-sm font-bold uppercase tracking-[0.7px] text-primary">
        {t.eyebrow}
      </p>
      <h2 class="mt-4 font-heading text-2xl font-bold uppercase leading-tight text-burgundy sm:text-3xl lg:text-4xl">
        {t.title}
      </h2>
    </div>

    <!-- Tarjetas de hito (reveal escalonado; la elevación va en el div interno
         para no chocar con el transform del reveal) -->
    <ul class="mt-14 grid grid-cols-1 items-stretch gap-5 sm:grid-cols-3 sm:gap-6">
      {
        milestones.map((m, i) => (
          <li data-reveal style={`--reveal-delay:${i * 160}ms`}>
            <div
              class:list={[
                "flex h-full flex-col rounded-3xl p-7 sm:p-8",
                m.highlight
                  ? "bg-primary text-white shadow-[0px_24px_50px_-12px_rgb(196_0_54/0.45)] sm:-translate-y-3"
                  : "border border-burgundy/10 bg-white text-burgundy shadow-[0px_12px_30px_-14px_rgb(84_5_69/0.25)]",
              ]}
            >
              <div class="flex items-center justify-between">
                <span
                  class:list={[
                    "font-heading text-sm font-bold uppercase tracking-[0.6px]",
                    m.highlight ? "text-white/90" : "text-primary",
                  ]}
                >
                  {m.role}
                </span>
                <span
                  class:list={[
                    "font-heading text-sm font-bold tabular-nums",
                    m.highlight ? "text-white/70" : "text-burgundy/45",
                  ]}
                >
                  {m.year}
                </span>
              </div>

              <span
                class="mt-6 font-heading text-5xl font-bold leading-none tabular-nums sm:text-6xl"
                data-count={m.value}
                data-count-dur="1800"
              >
                {fmt(m.value)}
              </span>
              <span
                class:list={[
                  "mt-3 font-body text-sm",
                  m.highlight ? "text-white/75" : "text-ink",
                ]}
              >
                {t.unit}
              </span>
            </div>
          </li>
        ))
      }
    </ul>

    <!-- Crecimiento -->
    <div class="mt-10 flex justify-center">
      <div class="inline-flex items-center gap-2.5 rounded-full bg-white px-5 py-2.5 shadow-[0px_10px_24px_-12px_rgb(84_5_69/0.3)]">
        <Icon name="growth" class="size-4 text-primary" />
        <span class="font-heading text-base font-bold text-primary tabular-nums">{t.growthValue}</span>
        <span class="font-body text-sm text-ink">{t.growthLabel}</span>
      </div>
    </div>
  </div>
</section>

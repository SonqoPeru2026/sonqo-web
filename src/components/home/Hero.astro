---
import { getLang, useTranslations } from "@/i18n/utils";

const lang = getLang(Astro.url);
const hero = useTranslations(lang, "hero");
---

<section id="hero" class="grid min-h-dvh place-items-center text-center">
  <div>
    <h1 class="font-heading text-6xl font-bold text-primary">{hero.title}</h1>
    <p class="mt-4 font-body text-lg text-burgundy">{hero.subtitle}</p>
  </div>
</section>

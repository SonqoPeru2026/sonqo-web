---
import { Icon } from "astro-icon/components";
import { getLang, useTranslations, localizePath } from "@/i18n/utils";

const lang = getLang(Astro.url);
const hero = useTranslations(lang, "hero");

const stats = [
  { value: hero.childrenValue, label: hero.childrenLabel },
  { value: hero.communitiesValue, label: hero.communitiesLabel },
];
---

<section id="inicio" class="flex min-h-dvh items-center bg-[linear-gradient(to_bottom,var(--color-primary)_0%,var(--color-primary)_85%,var(--color-coral)_100%)] pt-[112px] text-white">
  <div class="mx-auto grid w-full max-w-[1280px] items-center gap-[30px] px-8 pb-16 lg:grid-cols-2">
    <!-- Columna texto -->
    <div>
      <span
        class="inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-1.5 font-body text-sm font-medium"
      >
        <Icon name="hero-heart" class="h-3.5 w-auto" />
        {hero.badge}
      </span>

      <h1
        class="mt-6 font-heading text-5xl font-bold uppercase leading-tight [text-shadow:0_6px_12px_rgb(0_0_0/0.25)] sm:text-6xl"
      >
        {hero.title}
      </h1>

      <p class="mt-6 max-w-md font-body font-medium text-white/90">
        {hero.description}
      </p>

      <!-- Stats -->
      <dl
        class="mt-8 inline-flex items-center gap-8 rounded-2xl border border-white/[0.59] px-6 py-4 backdrop-blur-[6px]"
      >
        {
          stats.map((s, i) => (
            <>
              {i > 0 && <div aria-hidden class="h-10 w-px self-center bg-white/50" />}
              <div>
                <dt class="font-heading text-2xl font-bold leading-8">{s.value}</dt>
                <dd class="mt-1 font-body text-xs font-medium uppercase tracking-wide text-white/80">
                  {s.label}
                </dd>
              </div>
            </>
          ))
        }
      </dl>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-center">
        <a
          href={localizePath("/donate", lang)}
          class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-white px-6 py-3 font-heading text-sm font-bold uppercase tracking-wide text-primary transition-colors hover:bg-white/90 sm:w-auto"
        >
          <Icon name="hero-donate" class="h-5 w-auto" />
          {hero.ctaDonate}
        </a>
        <a
          href="#proposito"
          class="inline-flex w-full items-center justify-center rounded-full border border-white px-6 py-3 font-heading text-sm font-bold text-white transition-colors hover:bg-white/10 sm:w-auto"
        >
          {hero.ctaMore}
        </a>
      </div>

      <!-- Pago seguro -->
      <p class="mt-4 flex items-center justify-center gap-2 font-body text-[13px] text-white/70 sm:justify-start">
        <Icon name="hero-lock" class="h-5 w-auto" />
        {hero.secureLabel}
      </p>
    </div>

    <!-- Columna imagen (corazón) -->
    <div class="flex justify-center lg:justify-end">
      <img
        src="/images/hero-sonqo.webp"
        alt={hero.title}
        width="600"
        height="600"
        class="h-auto w-full"
      />
    </div>
  </div>
</section>

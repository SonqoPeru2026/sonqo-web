---
import { Icon } from "astro-icon/components";
import { getLang, useTranslations, localizePath } from "@/i18n/utils";

const lang = getLang(Astro.url);
const hero = useTranslations(lang, "hero");

// Cada slide: imagen + eyebrow con icono + texto + CTA (algunos con 2º botón).
// Reemplaza imágenes en public/images/hero/.
type Slide = {
  img: string;
  eyebrow: string;
  icon: string;
  title: string;
  text: string;
  cta: string;
  ctaIcon: string;
  ctaIconClass?: string;
  href: string;
  cta2?: string;
  href2?: string;
};
const ICON = "h-5 w-auto";
const slides: Slide[] = [
  { img: "hero-1.jpeg", eyebrow: hero.slide1Eyebrow, icon: "hero-heart", title: hero.slide1Title, text: hero.slide1Text, cta: hero.slide1Cta, ctaIcon: "hero-donate", href: localizePath("/donate", lang), cta2: hero.slide1Cta2, href2: "#proposito" },
  { img: "hero-2.png", eyebrow: hero.slide2Eyebrow, icon: "how-happy", title: hero.slide2Title, text: hero.slide2Text, cta: hero.slide2Cta, ctaIcon: "faq-chevron", ctaIconClass: "h-4 w-auto -rotate-90", href: "#proposito" },
  { img: "hero-3.png", eyebrow: hero.slide3Eyebrow, icon: "purpose-download", title: hero.slide3Title, text: hero.slide3Text, cta: hero.slide3Cta, ctaIcon: "purpose-download", href: localizePath("/infographic", lang) },
  { img: "hero-4.webp", eyebrow: hero.slide4Eyebrow, icon: "contact-mail", title: hero.slide4Title, text: hero.slide4Text, cta: hero.slide4Cta, ctaIcon: "contact-mail", href: "#contacto" },
];
const SLIDE_MS = 6000;

const RING_R = 16;
const RING_C = +(2 * Math.PI * RING_R).toFixed(2);
---

<section
  id="inicio"
  data-hero
  style={`--slide-ms:${SLIDE_MS}ms`}
  class="relative h-[65vh] min-h-[600px] max-h-[800px] overflow-hidden text-white lg:rounded-br-[72px]"
>
  <!-- Slides en un track que se desliza horizontalmente -->
  <div data-hero-track class="hero-track flex h-full w-full">
    {
      slides.map((s, i) => (
        <div data-slide={i} class="relative h-full w-full shrink-0">
          <img
            src={`/images/hero/${s.img}`}
            alt=""
            aria-hidden="true"
            fetchpriority={i === 0 ? "high" : undefined}
            loading={i === 0 ? "eager" : "lazy"}
            class="absolute inset-0 h-full w-full object-cover"
          />
          <div
            aria-hidden="true"
            class="absolute inset-0 bg-[linear-gradient(to_right,rgb(0_0_0/0.72)_0%,rgb(0_0_0/0.45)_45%,rgb(0_0_0/0.1)_100%)]"
          />
          <div class="relative mx-auto flex h-full max-w-[1280px] items-center px-8 pb-28 pt-[112px]">
            <div class="max-w-xl">
              <span class="inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-1.5 font-heading text-xs font-bold uppercase tracking-wide backdrop-blur-sm">
                <Icon name={s.icon} class="h-3.5 w-auto" />
                {s.eyebrow}
              </span>

              <h2
                class="mt-5 font-heading text-4xl font-bold uppercase leading-tight [text-shadow:0_6px_16px_rgb(0_0_0/0.4)] sm:text-5xl lg:text-6xl"
                set:html={s.title}
              />
              <p class="mt-5 max-w-md font-body text-base font-medium text-white/90 sm:text-lg">
                {s.text}
              </p>

              <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
                <a
                  href={s.href}
                  class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-7 py-3 font-heading text-sm font-bold uppercase tracking-wide text-primary transition-colors hover:bg-white/90"
                >
                  <Icon name={s.ctaIcon} class={s.ctaIconClass ?? ICON} />
                  {s.cta}
                </a>
                {
                  s.cta2 && s.href2 && (
                    <a
                      href={s.href2}
                      class="inline-flex items-center justify-center rounded-full border border-white px-7 py-3 font-heading text-sm font-bold uppercase tracking-wide text-white transition-colors hover:bg-white/10"
                    >
                      {s.cta2}
                    </a>
                  )
                }
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <!-- Flechas -->
  <button
    type="button"
    data-hero-prev
    aria-label="Anterior"
    class="absolute left-4 top-1/2 z-10 hidden size-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white backdrop-blur-sm transition-colors hover:bg-white/25 sm:flex"
  >
    <Icon name="faq-chevron" class="h-5 w-auto rotate-90" />
  </button>
  <button
    type="button"
    data-hero-next
    aria-label="Siguiente"
    class="absolute right-4 top-1/2 z-10 hidden size-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white backdrop-blur-sm transition-colors hover:bg-white/25 sm:flex"
  >
    <Icon name="faq-chevron" class="h-5 w-auto -rotate-90" />
  </button>

  <!-- Indicadores con timer circular -->
  <div class="absolute bottom-6 left-0 right-0 z-10 flex justify-center gap-3">
    {
      slides.map((_, i) => (
        <button
          type="button"
          data-hero-dot={i}
          aria-label={`Slide ${i + 1}`}
          class:list={["hero-dot relative size-10", i === 0 && "is-active"]}
        >
          <svg class="size-full -rotate-90" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r={RING_R} stroke="rgb(255 255 255 / 0.35)" stroke-width="2" />
            <circle
              class="ring"
              cx="20"
              cy="20"
              r={RING_R}
              stroke="white"
              stroke-width="2"
              stroke-linecap="round"
              stroke-dasharray={RING_C}
              stroke-dashoffset={RING_C}
            />
          </svg>
          <span class="absolute inset-0 flex items-center justify-center font-heading text-sm font-bold text-white">
            {i + 1}
          </span>
        </button>
      ))
    }
  </div>
</section>

<script>
  function initHeroCarousel() {
    const root = document.querySelector<HTMLElement>("[data-hero]");
    if (!root || root.dataset.bound) return;
    root.dataset.bound = "true";

    const track = root.querySelector<HTMLElement>("[data-hero-track]");
    const slides = [...root.querySelectorAll<HTMLElement>("[data-slide]")];
    const dots = [...root.querySelectorAll<HTMLElement>("[data-hero-dot]")];
    const count = slides.length;
    if (!track || count <= 1) return;

    const ms = parseInt(getComputedStyle(root).getPropertyValue("--slide-ms")) || 6000;
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    let index = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    function show(i: number) {
      index = (i + count) % count;
      track!.style.transform = `translateX(${-index * 100}%)`;
      dots.forEach((d, n) => {
        const active = n === index;
        d.classList.toggle("is-active", active);
        d.setAttribute("aria-current", active ? "true" : "false");
      });
    }
    function next() {
      show(index + 1);
    }
    function start() {
      if (reduce) return;
      stop();
      timer = setInterval(next, ms);
    }
    function stop() {
      if (timer) clearInterval(timer);
    }

    root.querySelector("[data-hero-next]")?.addEventListener("click", () => {
      next();
      start();
    });
    root.querySelector("[data-hero-prev]")?.addEventListener("click", () => {
      show(index - 1);
      start();
    });
    dots.forEach((d, n) =>
      d.addEventListener("click", () => {
        show(n);
        start();
      }),
    );

    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);
    root.addEventListener("focusin", stop);
    root.addEventListener("focusout", start);

    show(0);
    start();
  }

  document.addEventListener("astro:page-load", initHeroCarousel);
</script>

<style>
  /* Deslizamiento horizontal de los slides */
  .hero-track {
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* El anillo del indicador activo se llena durante la duración del slide */
  .hero-dot.is-active .ring {
    animation: ring-fill var(--slide-ms) linear forwards;
  }
  @keyframes ring-fill {
    to {
      stroke-dashoffset: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-track {
      transition: none;
    }
    .hero-dot.is-active .ring {
      animation: none;
      stroke-dashoffset: 0;
    }
  }
</style>

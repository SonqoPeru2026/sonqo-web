---
import { Icon } from "astro-icon/components";
import { getLang, useTranslations } from "@/i18n/utils";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "aboutus");

const highlights = [t.highlight1, t.highlight2, t.highlight3];
---

<section id="nosotros" class="bg-cream py-24">
  <div class="mx-auto w-full max-w-[1280px] px-6 sm:px-8">
    <!-- Encabezado -->
    <div>
      <div class="flex items-center gap-4">
        <span class="h-0.5 w-8 bg-primary"></span>
        <span class="font-heading text-sm font-bold uppercase tracking-[0.7px] text-primary">
          {t.eyebrow}
        </span>
      </div>
      <h2 class="mt-6 font-heading text-3xl font-bold uppercase leading-tight text-burgundy sm:text-4xl lg:text-5xl">
        {t.title}
      </h2>
    </div>

    <!-- Contenido -->
    <div class="mt-12 grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- Imagen con decoración -->
      <div class="relative">
        <!-- forma decorativa detrás -->
        <div
          aria-hidden
          class="absolute -inset-3 -rotate-2 rounded-[44px] bg-gradient-to-br from-burgundy/15 to-primary/15 sm:-inset-4"
        >
        </div>
        <img
          src="/images/about-sonqo.webp"
          alt={t.imageAlt}
          width="446"
          height="540"
          class="relative aspect-[446/540] w-full rounded-[40px] object-cover shadow-[0px_24px_48px_-12px_rgb(84_5_69/0.25)]"
        />
        <!-- badge flotante -->
        <div
          class="absolute -bottom-5 right-5 flex items-center gap-3 rounded-2xl bg-white px-5 py-4 shadow-[0px_16px_32px_-8px_rgb(84_5_69/0.25)] sm:right-8"
        >
          <span class="font-heading text-4xl font-bold leading-none text-primary">
            {t.badgeNumber}
          </span>
          <span class="max-w-[7rem] font-body text-xs font-medium uppercase leading-tight tracking-wide text-burgundy">
            {t.badgeLabel}
          </span>
        </div>
      </div>

      <!-- Texto -->
      <div>
        <p class="font-body text-lg font-medium leading-relaxed text-burgundy">{t.paragraph1}</p>
        <p class="mt-5 font-body leading-relaxed text-ink sm:text-lg">{t.paragraph2}</p>
        <p class="mt-5 font-body leading-relaxed text-ink sm:text-lg">{t.paragraph3}</p>

        <!-- Highlights -->
        <ul class="mt-8 flex flex-col gap-3 border-t border-burgundy/10 pt-8 sm:flex-row sm:flex-wrap sm:gap-x-6">
          {
            highlights.map((item) => (
              <li class="inline-flex items-center gap-2 font-heading text-sm font-bold text-burgundy">
                <span class="flex size-6 items-center justify-center rounded-full bg-primary text-white">
                  <Icon name="check" class="h-3.5 w-3.5" />
                </span>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

---
import { getLang, useTranslations, localizePath } from "@/i18n/utils";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "campaign");

// Métricas de campaña (placeholder hasta conectar Sanity).
const bars = [
  {
    label: t.bar1Label,
    current: 68400,
    goal: 165000,
    prefix: "S/",
    fill: "from-[#ff3d63] to-primary",
    glow: "shadow-[0px_2px_10px_0px_rgb(228_0_63/0.55)]",
    pill: "bg-primary",
    knob: "border-primary",
  },
  {
    label: t.bar2Label,
    current: 2050,
    goal: 5000,
    prefix: "",
    fill: "from-[#8f295c] to-[#520f33]",
    glow: "shadow-[0px_2px_10px_0px_rgb(115_20_71/0.55)]",
    pill: "bg-[#731447]",
    knob: "border-[#731447]",
  },
];

const fmt = (n: number) => n.toLocaleString("en-US");
const progress = bars.map((b) => ({
  ...b,
  pct: Math.round((b.current / b.goal) * 100),
}));
---

<section id="campaign" class="bg-primary py-24 text-white">
  <div class="mx-auto w-full max-w-[900px] px-6 sm:px-8">
    <!-- Encabezado -->
    <div class="text-center">
      <p class="font-heading text-sm font-bold uppercase tracking-[0.7px] text-white/80">
        {t.eyebrow}
      </p>
      <h2 class="mt-3 font-heading text-3xl font-bold uppercase leading-tight sm:text-4xl lg:text-5xl">
        {t.title}
      </h2>
      <p class="mx-auto mt-4 max-w-xl font-body leading-relaxed text-white/90 sm:text-lg">
        {t.subtitle}
      </p>
    </div>

    <!-- Tarjeta de progreso -->
    <div class="mt-10 rounded-3xl bg-white p-6 text-ink shadow-[0px_24px_48px_-8px_rgb(77_0_20/0.18)] sm:p-10">
      <div class="space-y-8">
        {
          progress.map((bar) => (
            <div>
              <div class="flex flex-wrap items-end justify-between gap-2">
                <span class="font-heading text-base font-bold text-[#111827]">{bar.label}</span>
                <span class="text-sm">
                  <span class="font-heading text-lg font-bold text-primary">
                    {bar.prefix}
                    {fmt(bar.current)}
                  </span>
                  <span class="text-ink-400">
                    {" "}
                    {t.of} {bar.prefix}
                    {fmt(bar.goal)}
                  </span>
                </span>
              </div>

              <div class="relative mt-5 h-4 w-full rounded-full bg-black/[0.06]">
                {/* ticks 25/50/75% */}
                {[25, 50, 75].map((tick) => (
                  <span
                    class="absolute top-0 h-full w-0.5 bg-black/10"
                    style={`left:${tick}%`}
                  />
                ))}
                {/* relleno */}
                <div
                  class:list={[
                    "absolute inset-y-0 left-0 rounded-full bg-gradient-to-r",
                    bar.fill,
                    bar.glow,
                  ]}
                  style={`width:${bar.pct}%`}
                >
                  <span
                    class:list={[
                      "absolute right-0 top-1/2 size-5 -translate-y-1/2 translate-x-1/2 rounded-full border-2 bg-white shadow-md",
                      bar.knob,
                    ]}
                  />
                </div>
                {/* pastilla de porcentaje */}
                <span
                  class:list={[
                    "absolute -top-8 -translate-x-1/2 rounded-full px-2.5 py-0.5 font-heading text-xs font-bold text-white",
                    bar.pill,
                  ]}
                  style={`left:${bar.pct}%`}
                >
                  {bar.pct}%
                </span>
              </div>
            </div>
          ))
        }
      </div>

      <!-- CTA -->
      <div class="mt-10 flex flex-col items-center gap-4">
        <a
          href={localizePath("/donate", lang)}
          class="rounded-full bg-primary px-10 py-3.5 font-heading text-base font-bold uppercase tracking-wide text-white transition-colors hover:bg-primary/90"
        >
          {t.cta}
        </a>
        <p class="text-center font-body text-xs text-ink-400">{t.footnote}</p>
      </div>
    </div>
  </div>
</section>

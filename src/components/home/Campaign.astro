---
import { getLang, useTranslations, localizePath } from "@/i18n/utils";
import CampaignProgress from "@/components/home/CampaignProgress.astro";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "campaign");
---

<section id="campaign" class="bg-primary py-24 text-white">
  <div class="mx-auto w-full max-w-[900px] px-6 sm:px-8">
    <!-- Encabezado -->
    <div class="text-center">
      <p class="font-heading text-sm font-bold uppercase tracking-[0.7px] text-white/80">
        {t.eyebrow}
      </p>
      <h2 class="mt-3 font-heading text-3xl font-bold uppercase leading-tight sm:text-4xl lg:text-5xl">
        {t.title}
      </h2>
      <p class="mx-auto mt-4 max-w-xl font-body leading-relaxed text-white/90 sm:text-lg">
        {t.subtitle}
      </p>
    </div>

    <!-- Tarjeta de progreso -->
    <div class="mt-10 rounded-3xl bg-white p-6 text-ink shadow-[0px_24px_48px_-8px_rgb(77_0_20/0.18)] sm:p-10">
      <CampaignProgress />

      <!-- CTA -->
      <div class="mt-10 flex flex-col items-center gap-4">
        <a
          href={localizePath("/donate", lang)}
          class="rounded-full bg-primary px-10 py-3.5 font-heading text-base font-bold uppercase tracking-wide text-white transition-colors hover:bg-primary/90"
        >
          {t.cta}
        </a>
        <p class="text-center font-body text-xs text-ink-400">{t.footnote}</p>
      </div>
    </div>
  </div>
</section>

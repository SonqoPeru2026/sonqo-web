---
import { Icon } from "astro-icon/components";
import { getLang, useTranslations } from "@/i18n/utils";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "faq");

const email = "sonqoperusolidario@gmail.com";

const items = [
  { q: t.q1, a: t.a1 },
  { q: t.q2, a: t.a2 },
  { q: t.q3, a: t.a3 },
  { q: t.q4, a: t.a4 },
  { q: t.q5, a: t.a5 },
  { q: t.q6, a: t.a6 },
];
---

<section id="faq" class="bg-cream py-24">
  <div class="mx-auto grid w-full max-w-[1200px] items-start gap-12 px-6 sm:px-8 lg:grid-cols-2 lg:gap-16">
    <!-- Columna intro -->
    <div>
      <div class="flex items-center gap-4">
        <span class="h-0.5 w-8 bg-primary"></span>
        <span class="font-heading text-sm font-bold uppercase tracking-[0.7px] text-primary">
          {t.eyebrow}
        </span>
      </div>
      <h2 class="mt-6 font-heading text-3xl font-bold uppercase leading-tight text-burgundy sm:text-4xl lg:text-5xl">
        {t.title}
      </h2>
      <p class="mt-6 max-w-md font-body leading-relaxed text-ink sm:text-lg">{t.subtitle}</p>

      <div class="mt-8 max-w-md border-t border-burgundy/10 pt-6">
        <a href={`mailto:${email}`} class="group inline-flex items-center gap-3">
          <span class="flex size-10 shrink-0 items-center justify-center rounded-full bg-primary text-white transition-transform group-hover:scale-105">
            <Icon name="contact-mail" class="h-5 w-auto" />
          </span>
          <span>
            <span class="block font-heading text-xs font-bold uppercase tracking-wide text-primary">
              {t.contactLabel}
            </span>
            <span class="block font-body text-[#1b1c1c] group-hover:text-primary">{email}</span>
          </span>
        </a>
      </div>
    </div>

    <!-- Acordeón -->
    <div data-faq>
      {
        items.map((item, i) => (
          <div class="border-b border-burgundy/10">
            <button
              type="button"
              class="faq-trigger group peer flex w-full items-center gap-3 py-5 text-left"
              aria-expanded={i === 0 ? "true" : "false"}
            >
              <Icon
                name="purpose-heart"
                class="h-4 w-4 shrink-0 text-primary opacity-0 transition-opacity duration-200 group-aria-expanded:opacity-100"
              />
              <span class="flex-1 font-heading text-base font-bold text-[#1b1c1c] transition-colors group-aria-expanded:text-primary">
                {item.q}
              </span>
              <Icon
                name="faq-chevron"
                class="size-4 shrink-0 text-ink-400 transition-transform duration-300 group-aria-expanded:rotate-180 group-aria-expanded:text-primary"
              />
            </button>
            <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out peer-aria-expanded:grid-rows-[1fr]">
              <div class="overflow-hidden">
                <p class="pb-5 pl-7 font-body leading-relaxed text-ink">{item.a}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  // Acordeón: un panel abierto a la vez. Solo togglea aria-expanded;
  // la animación de abrir/cerrar es 100% CSS (grid-template-rows 0fr→1fr).
  document.querySelectorAll<HTMLElement>("[data-faq]").forEach((group) => {
    const triggers = group.querySelectorAll<HTMLButtonElement>(".faq-trigger");
    triggers.forEach((btn) => {
      btn.addEventListener("click", () => {
        const isOpen = btn.getAttribute("aria-expanded") === "true";
        triggers.forEach((b) => b.setAttribute("aria-expanded", "false"));
        btn.setAttribute("aria-expanded", String(!isOpen));
      });
    });
  });
</script>

---
import { getLang, useTranslations } from "@/i18n/utils";
import { getSiteSettings } from "@/lib/sanity";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "campaign");

// Metas (goal) editables por el equipo en Sanity; se leen en build (prerender).
const { metaRecaudada, metaNinos } = await getSiteSettings();

// `current` arranca en 0 (respaldo del build) y se reemplaza en runtime con el
// total REAL vía /api/campaign-progress. Si el fetch falla, queda en 0.
const bars = [
  {
    key: "raised",
    label: t.bar1Label,
    current: 0,
    goal: metaRecaudada,
    prefix: "S/",
    fill: "from-primary-300 to-primary",
    glow: "shadow-[0px_2px_10px_0px_rgb(228_0_63/0.55)]",
    pill: "bg-primary",
    knob: "border-primary",
  },
  {
    key: "kids",
    label: t.bar2Label,
    current: 0,
    goal: metaNinos,
    prefix: "",
    fill: "from-burgundy-400 to-burgundy-600",
    glow: "shadow-[0px_2px_10px_0px_rgb(84_5_69/0.55)]",
    pill: "bg-burgundy",
    knob: "border-burgundy",
  },
];

const fmt = (n: number) => n.toLocaleString("en-US");
const pctOf = (current: number, goal: number) =>
  goal > 0 ? Math.min(100, Math.round((current / goal) * 100)) : 0;
const progress = bars.map((b) => ({ ...b, pct: pctOf(b.current, b.goal) }));
---

<div class="space-y-8" data-campaign-progress>
  {
    progress.map((bar) => (
      <div data-bar={bar.key} data-state="pending">
        <div class="flex flex-col items-start gap-1 sm:flex-row sm:flex-wrap sm:items-end sm:justify-between sm:gap-2">
          <span class="font-heading text-base font-bold text-ink-900">{bar.label}</span>
          {/* Estado "pending": aún sin monto real (build o fetch fallido).
              Un 0% visible desmotiva; se muestra un chip neutral en su lugar. */}
          <span
            data-role="status"
            class="rounded-full bg-primary-50 px-3 py-1 font-heading text-xs font-bold uppercase tracking-wide text-primary"
          >
            {t.inProgress}
          </span>
          <span class="text-sm" data-role="value-wrap">
            <span class="font-heading text-lg font-bold text-primary">
              {bar.prefix}
              <span data-role="value">{fmt(bar.current)}</span>
            </span>
            <span class="text-ink-400">
              {" "}
              {t.of} {bar.prefix}
              {fmt(bar.goal)}
            </span>
          </span>
        </div>

        <div class="relative mt-10 h-4 w-full rounded-full bg-black/[0.06]">
          {[25, 50, 75].map((tick) => (
            <span class="absolute top-0 h-full w-0.5 bg-black/10" style={`left:${tick}%`} />
          ))}
          <div
            data-role="fill"
            class:list={[
              "absolute inset-y-0 left-0 rounded-full bg-gradient-to-r transition-[width] duration-1000 ease-out",
              bar.fill,
              bar.glow,
            ]}
            style={`width:${bar.pct}%`}
          >
            <span
              class:list={[
                "absolute right-0 top-1/2 size-5 -translate-y-1/2 translate-x-1/2 rounded-full border-2 bg-white shadow-md",
                bar.knob,
              ]}
            />
          </div>
          <span
            data-role="pill"
            class:list={[
              "absolute -top-8 -translate-x-1/2 rounded-full px-2.5 py-0.5 font-heading text-xs font-bold text-white transition-[left] duration-1000 ease-out",
              bar.pill,
            ]}
            style={`left:clamp(1.75rem, ${bar.pct}%, calc(100% - 1.75rem))`}
          >
            {bar.pct}%
          </span>
        </div>
      </div>
    ))
  }
</div>

<style>
  /* Estados de cada barra:
     - pending: sin dato real → chip "en curso", números y pill ocultos,
       la barra respira con un stub corto (sin % falso).
     - live: dato real recibido → vista normal. El JS cambia el estado. */
  [data-state="pending"] [data-role="value-wrap"] {
    display: none;
  }
  [data-state="live"] [data-role="status"] {
    display: none;
  }
  [data-state="pending"] [data-role="pill"] {
    visibility: hidden;
  }
  [data-state="pending"] [data-role="fill"] {
    width: 6% !important;
    animation: bar-breathe 2.2s ease-in-out infinite;
  }
  [data-state="pending"] [data-role="fill"] span {
    display: none;
  }
  @keyframes bar-breathe {
    50% {
      opacity: 0.5;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    [data-state="pending"] [data-role="fill"] {
      animation: none;
    }
  }
</style>

<script define:vars={{ goalRaised: metaRecaudada, goalKids: metaNinos }}>
  function initCampaignProgress() {
    const root = document.querySelector("[data-campaign-progress]");
    if (!root) return;

    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const fmt = (n) => Math.round(n).toLocaleString("en-US");
    const pctOf = (current, goal) =>
      goal > 0 ? Math.min(100, Math.round((current / goal) * 100)) : 0;

    const render = (key, current, goal, animate) => {
      const bar = root.querySelector(`[data-bar="${key}"]`);
      if (!bar) return;
      bar.dataset.state = "live"; // sale del estado "en curso"
      const pct = pctOf(current, goal);
      const valueEl = bar.querySelector('[data-role="value"]');
      bar.querySelector('[data-role="fill"]').style.width = `${pct}%`;
      const pill = bar.querySelector('[data-role="pill"]');
      pill.style.left = `clamp(1.75rem, ${pct}%, calc(100% - 1.75rem))`;
      pill.textContent = `${pct}%`;

      if (!animate) {
        valueEl.textContent = fmt(current);
        return;
      }
      const dur = 1300;
      const ease = (t) => (t === 1 ? 1 : 1 - Math.pow(2, -10 * t));
      const start = performance.now();
      const tick = (now) => {
        const p = Math.min(1, (now - start) / dur);
        valueEl.textContent = fmt(current * ease(p));
        if (p < 1) requestAnimationFrame(tick);
        else valueEl.textContent = fmt(current);
      };
      requestAnimationFrame(tick);
    };

    let targets = null;
    let visible = false;
    let done = false;

    const run = () => {
      if (done || !targets || (!visible && !reduced)) return;
      done = true;
      render("raised", targets.raised, goalRaised, !reduced);
      render("kids", targets.kids, goalKids, !reduced);
    };

    if ("IntersectionObserver" in window && !reduced) {
      const io = new IntersectionObserver(
        (entries, obs) => {
          if (entries.some((e) => e.isIntersecting)) {
            visible = true;
            obs.disconnect();
            run();
          }
        },
        { threshold: 0.35 },
      );
      io.observe(root);
    } else {
      visible = true;
    }

    fetch("/api/campaign-progress")
      .then((res) => (res.ok ? res.json() : null))
      .then((data) => {
        // Sin dato o recaudación aún en 0 → se mantiene el estado "en curso".
        if (!data || data.raised == null || data.raised <= 0) return;
        targets = {
          raised: data.raised,
          kids: Math.round((data.raised / goalRaised) * goalKids),
        };
        run();
      })
      .catch(() => {});
  }

  document.addEventListener("astro:page-load", initCampaignProgress);
</script>

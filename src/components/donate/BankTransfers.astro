---

import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { getLang, useTranslations } from "@/i18n/utils";
import CopyRow from "@/components/donate/CopyRow.astro";
import venmoQr from "@/assets/images/donate-venmo-qr.webp";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "bankTransfers");

// Datos de cuentas (no traducibles).
const bcpSoles = [
  { label: t.soles, value: "193-2579491-0-63" },
  { label: "CCI", value: "00219300257949106315" },
];
const bcpDollars = [
  { label: t.dollars, value: "194-9944199-1-62" },
  { label: "CCI", value: "00219400994419916299" },
];
const interbank = [
  { label: t.soles, value: "200-3001754120" },
  { label: "CCI", value: "00320000300175412039" },
];
const venmoName = "Pablo-Lohmann";

const yapeName = "Sonqo Perú";
const yapeNumber = "+51 987 654 321";

const cardClass =
  "rounded-3xl border border-primary/10 bg-white p-6 shadow-[0px_10px_30px_-14px_rgb(0_0_0/0.1)] sm:p-8";
---

<section id="bank-transfers" class="bg-cream pb-24 pt-4" data-copy-section data-copied={t.copied}>
  <div class="mx-auto w-full max-w-[1280px] px-6 sm:px-8">
    <h2 class="text-center font-heading text-xl font-bold uppercase text-primary sm:text-2xl">
      {t.heading}
    </h2>
    <p class="mx-auto mt-3 max-w-2xl text-center font-body text-sm text-ink sm:text-base">
      {t.subtitle}
    </p>

    <div class="mt-10 space-y-6">
      <!-- BCP (ocupa todo el ancho por las 2 monedas) -->
      <article class={cardClass}>
        <Icon name="donate-bcp" class="h-8 w-auto" />
        <div class="mt-6 grid gap-x-10 gap-y-4 sm:grid-cols-2">
          <div class="space-y-4">
            {bcpSoles.map((row) => <CopyRow label={row.label} value={row.value} copyLabel={t.copy} />)}
          </div>
          <div class="space-y-4">
            {bcpDollars.map((row) => <CopyRow label={row.label} value={row.value} copyLabel={t.copy} />)}
          </div>
        </div>
      </article>

      <!-- Interbank · PayPal -->
      <div class="grid gap-6 sm:grid-cols-2">
        <article class={cardClass}>
          <Icon name="donate-interbank" class="h-8 w-auto" />
          <div class="mt-6 space-y-4">
            {interbank.map((row) => <CopyRow label={row.label} value={row.value} copyLabel={t.copy} />)}
          </div>
        </article>

        <article class={cardClass}>
          <Icon name="donate-paypal" class="h-7 w-auto" />
          <div class="mt-6 space-y-4">
            <CopyRow label={t.email} value="contacto@sonqoperu.com" copyLabel={t.copy} />
            <CopyRow label={t.name} value="Pablo Lohmann" copyLabel={t.copy} copyable={false} />
          </div>
        </article>
      </div>

      <div class="grid gap-6 sm:grid-cols-2">
        <article class={cardClass}>
          <Icon name="donate-venmo" class="h-12 w-auto" />
          <div class="mt-6 flex flex-col items-center gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <span class="inline-block rounded bg-primary/10 px-2 py-0.5 font-heading text-xs font-bold text-primary">
                {t.name}
              </span>
              <p class="mt-1 font-body text-ink-900">{venmoName}</p>
            </div>
            <Image
              src={venmoQr}
              alt={t.venmoQrAlt}
              width={256}
              quality={90}
              loading="lazy"
              class="size-24 shrink-0 rounded-xl border border-ink-100 bg-white p-1.5 sm:size-32"
            />
          </div>
        </article>

        <article class={`${cardClass} relative overflow-hidden`} aria-label={`Yape · ${t.comingSoon}`}>
          <!-- Contenido atenuado (aún no disponible) -->
          <div class="pointer-events-none select-none blur-[2px] grayscale opacity-40" aria-hidden="true">
            <Icon name="checkout-yape" class="h-10 w-auto text-primary" />
            <div class="mt-6 flex flex-col items-center gap-4 sm:flex-row sm:items-center sm:justify-between">
              <div class="space-y-3">
                <CopyRow label={t.yapeNumber} value={yapeNumber} copyLabel={t.copy} />
                <div>
                  <span class="inline-block rounded bg-primary/10 px-2 py-0.5 font-heading text-xs font-bold text-primary">
                    {t.name}
                  </span>
                  <p class="mt-1 font-body text-ink-900">{yapeName}</p>
                </div>
              </div>
              <Image
                src={venmoQr}
                alt={t.yapeQrAlt}
                width={256}
                quality={90}
                loading="lazy"
                class="size-24 shrink-0 rounded-xl border border-ink-100 bg-white p-1.5 sm:size-32"
              />
            </div>
          </div>

          <!-- Banner diagonal "Muy pronto" -->
          <div class="pointer-events-none absolute inset-0 flex items-center justify-center">
            <div
              class="w-[160%] -rotate-[10deg] bg-primary py-2.5 text-center shadow-[0_8px_24px_-6px_rgb(228_0_63/0.5)] sm:py-3"
            >
              <span class="font-heading text-lg font-bold uppercase tracking-[0.25em] text-white sm:text-xl">
                {t.comingSoon}
              </span>
            </div>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<script>
  // Copiar al portapapeles con feedback temporal.
  function initCopy() {
    document.querySelectorAll<HTMLElement>("[data-copy-section]").forEach((section) => {
      const copiedText = section.dataset.copied ?? "✓";
      section.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
        const label = btn.querySelector(".copy-label");
        const original = label?.textContent ?? "";
        btn.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText(btn.dataset.copy ?? "");
            if (!label) return;
            label.textContent = copiedText;
            btn.classList.add("is-copied");
            setTimeout(() => {
              label.textContent = original;
              btn.classList.remove("is-copied");
            }, 1500);
          } catch {
            /* clipboard no disponible */
          }
        });
      });
    });
  }
  document.addEventListener("astro:page-load", initCopy);
</script>

<style>
  .copy-btn.is-copied {
    background-color: var(--color-primary);
    color: #fff;
  }
</style>

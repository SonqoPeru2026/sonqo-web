---
import { getLang, useTranslations } from "@/i18n/utils";
import { getDonateHeroImage } from "@/lib/sanity";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "donateHero");

// Imagen editable por el equipo en Sanity (leída en build; fallback = la local).
const heroImg = await getDonateHeroImage();
---

<section class="relative isolate flex min-h-[60vh] items-center overflow-hidden pt-[140px] pb-16 text-white">
  <!-- Imagen de fondo (LCP: priority = eager + fetchpriority high + preload) -->
  <img
    src={heroImg.src}
    srcset={heroImg.srcset}
    sizes="100vw"
    width={heroImg.width}
    height={heroImg.height}
    alt=""
    aria-hidden="true"
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 -z-20 h-full w-full object-cover object-[center_45%]"
  />

  <div
    aria-hidden="true"
    class="absolute inset-0 -z-10"
    style="background: linear-gradient(to top, rgb(15 15 18 / 0.75) 0%, rgb(15 15 18 / 0.5) 50%, rgb(15 15 18 / 0.3) 100%);"
  >
  </div>

  <div class="mx-auto w-full max-w-[1280px] px-6 text-center sm:px-8">
    <span
      class="inline-flex items-center rounded-full bg-primary px-4 py-1.5 font-heading text-xs font-bold uppercase tracking-[0.15em] shadow-lg"
    >
      {t.badge}
    </span>
    <h1
      class="mx-auto mt-6 max-w-3xl font-heading text-4xl font-bold leading-tight [text-shadow:0_4px_16px_rgb(0_0_0/0.35)] sm:text-5xl"
    >
      {t.title}
    </h1>
    <p class="mx-auto mt-5 max-w-2xl font-body leading-relaxed text-white/90 sm:text-lg">
      {t.subtitle}
    </p>
  </div>
</section>

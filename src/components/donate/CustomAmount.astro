---
import { getLang, useTranslations } from "@/i18n/utils";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "customAmount");

// Montos rápidos sugeridos.
const quick = [50, 100, 200, 500];
---

<div class="mx-auto max-w-xl rounded-3xl border border-primary/15 bg-white p-6 shadow-[0px_10px_30px_-10px_rgb(0_0_0/0.08)] sm:p-8">
  <label for="custom-amount-input" class="block font-heading text-sm font-bold text-burgundy">
    {t.label}
  </label>

  <div class="mt-4 flex items-center gap-2 rounded-2xl border border-[#e5e7eb] bg-white px-4 py-3 focus-within:border-primary focus-within:ring-2 focus-within:ring-primary/20">
    <span class="font-heading text-xl font-bold text-ink-400">{t.currency}</span>
    <input
      id="custom-amount-input"
      type="number"
      min="10"
      step="1"
      inputmode="numeric"
      placeholder="0"
      class="w-full bg-transparent font-heading text-2xl font-bold text-burgundy outline-none placeholder:text-ink-200"
    />
  </div>
  <p class="mt-2 font-body text-xs text-ink-400">{t.minNote}</p>

  <div class="mt-4 grid grid-cols-4 gap-2">
    {
      quick.map((amount) => (
        <button
          type="button"
          data-quick-amount={amount}
          class="rounded-xl border border-primary/20 py-2 font-heading text-sm font-bold text-primary transition-colors hover:bg-primary hover:text-white"
        >
          {t.currency}
          {amount}
        </button>
      ))
    }
  </div>

  <a
    href="#"
    class="mt-6 block rounded-full bg-primary py-3.5 text-center font-heading text-sm font-bold uppercase tracking-wide text-white transition-colors hover:bg-primary-600"
  >
    {t.donate}
  </a>
</div>

<script>
  function initCustomAmount() {
    const input = document.getElementById("custom-amount-input") as HTMLInputElement | null;
    if (!input) return;
    document.querySelectorAll<HTMLButtonElement>("[data-quick-amount]").forEach((btn) => {
      btn.addEventListener("click", () => {
        input.value = btn.dataset.quickAmount ?? "";
        input.focus();
      });
    });
  }
  document.addEventListener("astro:page-load", initCustomAmount);
</script>

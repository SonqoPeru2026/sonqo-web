---
import { Icon } from "astro-icon/components";
import { getLang, useTranslations, localizePath } from "@/i18n/utils";
import CustomAmount from "@/components/donate/CustomAmount.astro";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "packageCard");

// Precios editables en Sanity (placeholder por ahora).
const packages = [
  { id: "aliado", name: t.aliadoName, price: 33, impact: t.impact1 },
  { id: "ninos", name: t.ninosName, price: 165, impact: t.impact5 },
  { id: "corazon", name: t.corazonName, price: 330, impact: t.impact10 },
  { id: "comunidad", name: t.comunidadName, price: 660, impact: t.impact20 },
];

const fmt = (n: number) => n.toLocaleString("en-US");
const donateHref = localizePath("/donate", lang);
---

<section id="packages" class="bg-cream py-20">
  <div class="mx-auto w-full max-w-[1200px] px-6 sm:px-8">
    <h2 class="text-center font-heading text-2xl font-bold uppercase text-burgundy sm:text-3xl">
      {t.heading}
    </h2>

    <!-- Toggle Sugeridos / Otro monto -->
    <div class="mt-8 flex justify-center">
      <div
        class="grid w-full max-w-[320px] grid-cols-2 rounded-full bg-ink-100 p-1"
        role="tablist"
        data-amount-tabs
      >
        <button
          type="button"
          role="tab"
          aria-selected="true"
          data-tab="suggested"
          class="relative rounded-full py-2.5 text-center font-heading text-sm font-bold text-ink-500 transition-all duration-200 aria-selected:z-10 aria-selected:scale-[1.06] aria-selected:bg-primary aria-selected:text-white aria-selected:shadow-md"
        >
          {t.tabSuggested}
        </button>
        <button
          type="button"
          role="tab"
          aria-selected="false"
          data-tab="custom"
          class="relative rounded-full py-2.5 text-center font-heading text-sm font-bold text-ink-500 transition-all duration-200 aria-selected:z-10 aria-selected:scale-[1.06] aria-selected:bg-primary aria-selected:text-white aria-selected:shadow-md"
        >
          {t.tabCustom}
        </button>
      </div>
    </div>

    <!-- Panel: paquetes sugeridos -->
    <div data-panel="suggested" class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        packages.map((pkg) => (
          <div class="flex flex-col rounded-2xl border border-primary/20 bg-white p-6 text-center shadow-[0px_10px_30px_-12px_rgb(0_0_0/0.08)] transition-all hover:-translate-y-1 hover:border-primary hover:shadow-[0px_18px_40px_-12px_rgb(228_0_63/0.25)]">
            <p class="font-heading text-xs font-bold uppercase tracking-[0.15em] text-ink-400">
              {t.packageLabel}
            </p>
            <h3 class="mt-1 font-heading text-lg font-bold text-burgundy">{pkg.name}</h3>
            <p class="mt-5 flex items-baseline justify-center gap-1 font-heading font-bold text-primary">
              <span class="text-xl">S/</span>
              <span class="text-5xl leading-none">{fmt(pkg.price)}</span>
            </p>
            <p class="mt-5 flex-1 font-body text-sm leading-relaxed text-ink">{pkg.impact}</p>
            <a
              href={donateHref}
              data-package={pkg.id}
              class="mt-6 block rounded-full bg-primary py-3 font-heading text-sm font-bold uppercase tracking-wide text-white transition-colors hover:bg-primary-600"
            >
              {t.donate}
            </a>
          </div>
        ))
      }
    </div>

    <!-- Panel: otro monto -->
    <div data-panel="custom" class="mt-10 hidden">
      <CustomAmount />
    </div>

    <!-- Sellos de confianza -->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4 text-ink-500">
      <span class="inline-flex items-center gap-2 text-sm">
        <Icon name="hero-lock" class="h-4 w-auto text-primary" />
        {t.trustSecure}
      </span>
      <span class="inline-flex items-center gap-2 text-sm">
        <Icon name="check" class="h-4 w-4 rounded-full bg-primary p-0.5 text-white" />
        {t.trustHonorem}
      </span>
      <Icon name="donate-visa" class="h-4 w-auto" />
      <Icon name="donate-mastercard-1" class="h-6 w-auto" />
      <Icon name="donate-paypal" class="h-5 w-auto" />
      <span class="inline-flex items-center gap-1.5 rounded-full border border-ink-200 px-3 py-1 text-xs">
        <Icon name="donate-ssl" class="h-3.5 w-auto" />
        {t.trustSsl}
      </span>
    </div>
  </div>
</section>

<script>
  // Cambia entre paquetes sugeridos y monto personalizado.
  function initAmountTabs() {
    document.querySelectorAll<HTMLElement>("[data-amount-tabs]").forEach((tabs) => {
      const buttons = tabs.querySelectorAll<HTMLButtonElement>("[data-tab]");
      const section = tabs.closest("section");
      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const target = btn.dataset.tab;
          buttons.forEach((b) =>
            b.setAttribute("aria-selected", String(b.dataset.tab === target)),
          );
          section?.querySelectorAll<HTMLElement>("[data-panel]").forEach((panel) => {
            panel.classList.toggle("hidden", panel.dataset.panel !== target);
          });
        });
      });
    });
  }
  document.addEventListener("astro:page-load", initAmountTabs);
</script>

---
import { getLang, useTranslations, localizePath } from "@/i18n/utils";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "thanks");

const status = Astro.url.searchParams.get("status") ?? "approved";
const approved = status === "approved";

const homeHref = localizePath("/", lang);
const donateHref = localizePath("/donate", lang);

// Circumference = 2 * π * r (r=25) ≈ 157
const C = 157;
// Check path length ≈ 48
const CL = 48;
---

<section class="flex h-screen items-center justify-center bg-cream px-6">
  <div class="mx-auto flex w-full max-w-lg flex-col items-center text-center">
    <!-- Animated circle + check -->
    <div class:list={["thanks-icon", approved ? "thanks-icon--success" : "thanks-icon--fail"]}>
      <svg viewBox="0 0 52 52" class="h-20 w-20 sm:h-24 sm:w-24" aria-hidden="true">
        <circle
          class="thanks-circle"
          cx="26" cy="26" r="25"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          style={`stroke-dasharray: ${C}; stroke-dashoffset: ${C};`}
        />
        {
          approved ? (
            <path
              class="thanks-check"
              d="M14.1 27.2l7.1 7.2 16.7-16.8"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
              style={`stroke-dasharray: ${CL}; stroke-dashoffset: ${CL};`}
            />
          ) : (
            <g class="thanks-x" stroke="currentColor" stroke-width="3" stroke-linecap="round">
              <line x1="16" y1="16" x2="36" y2="36" style={`stroke-dasharray: 28; stroke-dashoffset: 28;`} />
              <line x1="36" y1="16" x2="16" y2="36" style={`stroke-dasharray: 28; stroke-dashoffset: 28;`} />
            </g>
          )
        }
      </svg>
    </div>

    <h1 class="mt-8 font-heading text-3xl font-bold text-burgundy-900 sm:text-4xl">
      {approved ? t.approvedTitle : t.rejectedTitle}
    </h1>
    <p class="mt-4 max-w-md font-body text-base text-ink-500 sm:text-lg">
      {approved ? t.approvedText : t.rejectedText}
    </p>

    <div class="mt-10 flex flex-col gap-4 sm:flex-row">
      {
        !approved && (
          <a
            href={donateHref}
            class="inline-flex min-w-[200px] items-center justify-center rounded-full bg-primary px-8 py-3.5 font-heading text-sm font-bold uppercase tracking-wide text-white transition-colors hover:bg-primary-600"
          >
            {t.retry}
          </a>
        )
      }
      <a
        href={homeHref}
        class:list={[
          "inline-flex min-w-[200px] items-center justify-center rounded-full px-8 py-3.5 font-heading text-sm font-bold uppercase tracking-wide transition-colors",
          approved
            ? "bg-primary text-white hover:bg-primary-600"
            : "border border-primary text-primary hover:bg-primary hover:text-white",
        ]}
      >
        {t.backHome}
      </a>
    </div>
  </div>
</section>

<style>
  /* --- Estados de color --- */
  .thanks-icon--success { color: var(--color-primary); }
  .thanks-icon--fail { color: var(--color-ink-400); }

  /* --- Círculo se dibuja --- */
  .thanks-circle {
    transform-origin: center;
    transform: rotate(-90deg);
    animation: draw-circle 0.6s 0.1s cubic-bezier(0.65, 0, 0.35, 1) forwards;
  }

  /* --- Check se dibuja después del círculo --- */
  .thanks-check {
    animation: draw-check 0.35s 0.65s cubic-bezier(0.65, 0, 0.35, 1) forwards;
  }

  /* --- X se dibuja (estado rechazado) --- */
  .thanks-x line:first-child {
    animation: draw-check 0.3s 0.65s cubic-bezier(0.65, 0, 0.35, 1) forwards;
  }
  .thanks-x line:last-child {
    animation: draw-check 0.3s 0.8s cubic-bezier(0.65, 0, 0.35, 1) forwards;
  }

  /* --- Scale pop al completar --- */
  .thanks-icon--success {
    animation: icon-pop 0.4s 0.95s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  .thanks-icon--fail {
    animation: icon-pop 0.4s 1.05s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes draw-circle {
    to { stroke-dashoffset: 0; }
  }
  @keyframes draw-check {
    to { stroke-dashoffset: 0; }
  }
  @keyframes icon-pop {
    0% { transform: scale(0.8); }
    50% { transform: scale(1.08); }
    100% { transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .thanks-circle,
    .thanks-check,
    .thanks-x line,
    .thanks-icon--success,
    .thanks-icon--fail {
      animation: none !important;
      stroke-dashoffset: 0 !important;
      transform: none !important;
    }
  }
</style>

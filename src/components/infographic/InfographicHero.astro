---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { getLang, useTranslations } from "@/i18n/utils";
import heroImg from "@/assets/images/infografic-childens.webp";

const lang = getLang(Astro.url);
const t = useTranslations(lang, "infographic");
---

<section
  class="relative flex min-h-[68vh] items-center justify-center overflow-hidden pt-[112px] text-center text-white"
>
  <!-- Foto de fondo (LCP: priority = eager + fetchpriority high + preload) -->
  <Image
    src={heroImg}
    alt=""
    aria-hidden="true"
    priority
    sizes="100vw"
    quality={72}
    class="absolute inset-0 -z-20 h-full w-full object-cover object-[center_20%]"
  />
  <!-- Overlay negro 69% (Figma) para legibilidad del texto -->
  <div class="absolute inset-0 -z-10 bg-black/[0.69]"></div>

  <div class="mx-auto max-w-3xl px-6 pb-20">
    <span
      class="inline-flex items-center gap-2 rounded-full bg-primary px-4 py-1.5 font-heading text-xs font-bold uppercase tracking-wide shadow-sm"
    >
      <Icon name="purpose-download" class="h-3.5 w-auto" />
      {t.heroBadge}
    </span>

    <h1
      class="mt-6 font-heading text-4xl font-bold leading-tight [text-shadow:0_6px_16px_rgb(0_0_0/0.35)] sm:text-5xl"
    >
      {t.heroTitle}
    </h1>

    <p class="mx-auto mt-6 max-w-xl font-body text-base text-white/90 sm:text-lg">
      {t.heroSubtitle}
    </p>
  </div>
</section>

---
import Layout from "@/layouts/Layout.astro";
import { getLang, useTranslations } from "@/i18n/utils";
import NotFound from "@/components/common/NotFound.astro";

const lang = getLang(Astro.url);
const meta = useTranslations(lang, "meta");
---

<Layout title={meta.notFoundTitle}>
  <NotFound />
</Layout>

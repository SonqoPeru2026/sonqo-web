---
import Layout from "@/layouts/Layout.astro";
import { getLang, useTranslations } from "@/i18n/utils";
import Hero from "@/components/home/Hero.astro";
import Purpose from "@/components/home/Purpose.astro";
import Motivation from "@/components/home/Motivation.astro";
import AboutUs from "@/components/home/AboutUs.astro";
import Process from "@/components/home/Process.astro";
import History from "@/components/home/History.astro";
import Campaign from "@/components/home/Campaign.astro";
import Gallery from "@/components/home/Gallery.astro";

// Misma estructura que la home es; getLang detecta "/en" y los textos salen en inglés.
const lang = getLang(Astro.url);
const meta = useTranslations(lang, "meta");
---

<Layout title={meta.homeTitle} description={meta.homeDescription}>
  <Hero />
  <Purpose />
  <Process />
  <Motivation />
  <History />
  <Campaign />
  <Gallery />
  <AboutUs />
</Layout>

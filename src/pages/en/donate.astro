---
import Layout from "@/layouts/Layout.astro";
import { getLang, useTranslations } from "@/i18n/utils";
import PackageCard from "@/components/donate/PackageCard.astro";
import CustomAmount from "@/components/donate/CustomAmount.astro";
import BankTransfers from "@/components/donate/BankTransfers.astro";

const lang = getLang(Astro.url);
const meta = useTranslations(lang, "meta");
---

<Layout title={meta.donateTitle}>
  <PackageCard />
  <CustomAmount />
  <BankTransfers />
</Layout>

---
export const prerender = true;

import Layout from "@/layouts/Layout.astro";
import { getLang, useTranslations } from "@/i18n/utils";
import GalleryPage from "@/components/gallery/GalleryPage.astro";

const lang = getLang(Astro.url);
const meta = useTranslations(lang, "meta");
---

<Layout title={meta.galleryTitle} description={meta.galleryDescription}>
  <GalleryPage />
</Layout>

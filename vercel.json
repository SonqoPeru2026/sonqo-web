{
  "crons": [
    { "path": "/api/reports/donations-monthly", "schedule": "0 13 1 * *" },
    { "path": "/api/health/db", "schedule": "0 12 */3 * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
